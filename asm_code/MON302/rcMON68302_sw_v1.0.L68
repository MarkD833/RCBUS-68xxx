00601026                          1079  *------------------------------------------------------------------------------
00601026                          1080  * (O)utput a byte to I/O space address
00601026                          1081  *------------------------------------------------------------------------------
00601026                          1082  cmdIOWrite:
00601026  6100 04EA               1083      bsr.w   putCh           * echo back the command character in D0
0060102A  103C 0020               1084      move.b  #' ',d0
0060102E  6100 04E2               1085      bsr.w   putCh
00601032                          1086  
00601032  4282                    1087      clr.l   d2              * pre-set D2 to 0
00601034  7202                    1088      move.l  #2,d1           * read up to 2 digit address
00601036  6100 01D8               1089      bsr.w   hexToIntEcho    * from the serial port
0060103A  6500 FE96               1090      bcs.w   monLoop         * back to prompt if there's an error
0060103E  1600                    1091      move.b  d0,d3           * save the typed in 8-bit address
00601040  103C 003D               1092      move.b  #'=',d0
00601044  6100 04CC               1093      bsr.w   putCh           * send an EQUALS
00601048                          1094  
00601048  4282                    1095      clr.l   d2              * pre-set D2 to 0
0060104A  7202                    1096      move.l  #2,d1           * read up to 2 digit value
0060104C  6100 01C2               1097      bsr.w   hexToIntEcho    * from the serial port
00601050  6500 FE80               1098      bcs.w   monLoop         * back to prompt if there's an error
00601054                          1099  
00601054                          1100      ; D0 = value and D3 = 8-bit address
00601054  207C 00FD0000           1101      movea.l #RCIO_BASE,a0
0060105A  0283 000000FF           1102      andi.l  #$FF,d3         * clear all the unused bits
00601060  E383                    1103      asl.l   #1,d3           * make it a word offset
00601062  5283                    1104      addi.l  #1,d3           * make it an odd address to write to D0..D7
00601064  1180 3000               1105      move.b  d0,(0,a0,d3)    * and write the new value out
00601068                          1106  
00601068  6100 045E               1107      bsr.w   putCRLF
0060106C  6000 FE64               1108      bra.w   monLoop
00601070                          1109  
00601070                          1110  *------------------------------------------------------------------------------
00601070                          1111  * (S) - download a single line of a Motorola S-Record
00601070                          1112  *------------------------------------------------------------------------------
00601070                          1113  * Decode a single s-record that is held in one of the rx buffers and write it
00601070                          1114  * directly to RAM.
00601070                          1115  * A0 points to the SCC rx buffer holding the record inc the 'S' char
00601070                          1116  * A2 points to the SCC rx buffer descriptor flags register
00601070                          1117  *
00601070                          1118  * D0 = 0 if checksum OK or -1 if any error
00601070                          1119  * Uses:
00601070                          1120  *  D3 - running checksum
00601070                          1121  *------------------------------------------------------------------------------
00601070                          1122  cmdDownload:
00601070  4283                    1123      clr.l   d3              * running checksum sum = 0
00601072  5288                    1124      addq.l  #1, a0          * skip over 'S'
00601074                          1125  
00601074  1018                    1126      move.b  (a0)+, d0       * get s-record type
00601076  0400 0030               1127      sub.b   #'0', d0
0060107A  13C0 000FF820           1128      move.b  d0, srecType
00601080                          1129  
00601080  6100 01CC               1130      bsr     readHexByte     * read byte count
00601084  13C0 000FF821           1131      move.b  d0, srecByteCnt
0060108A  D600                    1132      add.b   d0, d3          * add byte count to checksum
0060108C                          1133  
0060108C                          1134      * Decode address based on record type
0060108C  4284                    1135      clr.l   d4              * D4 holds destination address
0060108E  0C39 0001 000FF820      1136      cmp.b   #1, srecType
00601096  6738                    1137      beq.s   .addr2bytes
00601098  0C39 0002 000FF820      1138      cmp.b   #2, srecType
006010A0  671E                    1139      beq.s   .addr3bytes
006010A2  0C39 0003 000FF820      1140      cmp.b   #3, srecType
006010AA  6704                    1141      beq.s   .addr4bytes
006010AC  6000 007E               1142      bra    .ignore
006010B0                          1143  
006010B0                          1144  .addr4Bytes:
006010B0  6100 019C               1145      bsr     readHexByte
006010B4  D600                    1146      add.b   d0, d3          * update checksum
006010B6  1800                    1147      move.b  d0, d4          * addr bits 24..31
006010B8  E18C                    1148      lsl.l   #8, d4          * shift ready for next byte
006010BA  5339 000FF821           1149      subi.b  #1, srecByteCnt * decrement byte count
006010C0                          1150      
006010C0                          1151  .addr3Bytes:
006010C0  6100 018C               1152      bsr     readHexByte
006010C4  D600                    1153      add.b   d0, d3          * update checksum
006010C6  1800                    1154      move.b  d0, d4          * addr bits 16..23
006010C8  E18C                    1155      lsl.l   #8, d4          * shift ready for next byte
006010CA  5339 000FF821           1156      subi.b  #1, srecByteCnt * decrement byte count
006010D0                          1157  
006010D0                          1158  .addr2Bytes:
006010D0  6100 017C               1159      bsr     readHexByte
006010D4  D600                    1160      add.b   d0, d3          * update checksum
006010D6  1800                    1161      move.b  d0, d4          * addr bits 8..15
006010D8  E18C                    1162      lsl.l   #8, d4          * shift ready for next byte
006010DA  6100 0172               1163      bsr     readHexByte
006010DE  D600                    1164      add.b   d0, d3          * update checksum
006010E0  1800                    1165      move.b  d0, d4          * addr bits 0..7
006010E2  5739 000FF821           1166      subi.b  #3, srecByteCnt * decrement byte count by 2 (+1 for csum)
006010E8                          1167  
006010E8                          1168      * D4 now holds the destination address
006010E8  2244                    1169      move.l  d4, a1          * A1 = target address to store data
006010EA  1839 000FF821           1170      move.b  srecByteCnt, d4 * D4 = no of data bytes to read in
006010F0                          1171  
006010F0                          1172      * Read data bytes and store at (A1)
006010F0                          1173  .rdLoop:
006010F0  4A04                    1174      tst.b   d4              * have we done yet?
006010F2  670C                    1175      beq.s   .rdChecksum
006010F4  6100 0158               1176      bsr     readHexByte
006010F8  D600                    1177      add.b   d0, d3          * update checksum
006010FA  12C0                    1178      move.b  d0, (a1)+       * write byte to memory
006010FC  5304                    1179      subq.b  #1, d4          * decrement byte count
006010FE  60F0                    1180      bra.s   .rdLoop
00601100                          1181  
00601100                          1182  .rdChecksum:
00601100  6100 014C               1183      bsr     readHexByte     * D0 = checksum byte
00601104  D600                    1184      add.b   d0, d3          * final sum
00601106  0C03 00FF               1185      cmpi.b  #$ff, d3        * all good if D3 = $FF
0060110A  6710                    1186      beq.s   .ok
0060110C                          1187  .fail:
0060110C  0052 8000               1188      ori.w   #$8000,(A2)     * signal buffer is free
00601110  103C 0058               1189      move.b  #'X', d0        * checksum fail - print an X
00601114  6100 03FC               1190      bsr     putCh
00601118  6000 FDC0               1191      bra.w   monLoop_NP      * return to main loop without prompt
0060111C                          1192  .ok:
0060111C  0052 8000               1193      ori.w   #$8000,(A2)     * signal buffer is free
00601120  103C 002E               1194      move.b  #'.', d0        * checksum good - print a dot
00601124  6100 03EC               1195      bsr     putCh
00601128  6000 FDB0               1196      bra.w   monLoop_NP      * return to main loop without prompt
0060112C                          1197  .ignore:
0060112C  0052 8000               1198      ori.w   #$8000,(A2)     * signal buffer is free
00601130  103C 003F               1199      move.b  #'?', d0        * unsupported record type - question mark
00601134  6100 03DC               1200      bsr     putCh
00601138  6100 038E               1201      bsr.w   putCRLF
0060113C  6000 FD94               1202      bra.w   monLoop
00601140                          1203  
00601140                          1204  *------------------------------------------------------------------------------
00601140                          1205  * Display the supported commands
00601140                          1206  *------------------------------------------------------------------------------
00601140                          1207  cmdHelp:
00601140  41FA 04DF               1208      lea     strCommands(PC), a0
00601144  6100 0386               1209      bsr.w   putString
00601148  6000 FD88               1210      bra.w   monLoop
0060114C                          1211  
0060114C                          1212  *------------------------------------------------------------------------------
0060114C                          1213  * Dumps a 256 section of RAM to the screen
0060114C                          1214  * Displays both hex values and ASCII characters
0060114C                          1215  * a0 - Start Address
0060114C                          1216  *------------------------------------------------------------------------------
0060114C                          1217  dumpRAM:
0060114C  48E7 E040               1218      movem.l d0-d2/a1, -(SP) * Save registers
00601150  2248                    1219      move.l  a0,a1           * move the start address to A1
00601152                          1220  
00601152  6100 0374               1221      bsr.w   putCRLF         * new line - trashes D0 & A0
00601156                          1222      
00601156  323C 000F               1223      move.w  #15,d1          * 16 rows of data (DBRA needs 1 less!)
0060115A                          1224  .dr_1:
0060115A  343C 000F               1225      move.w  #15,d2          * 16 bytes of data per row (DBRA needs 1 less!)
0060115E  2009                    1226      move.l  a1, d0          * copy the start address of the line into D0          
00601160  6100 0326               1227      bsr.w   writeAddr32     * Display as a 32-bit hex value
00601164  41FA 0640               1228      lea     strColonSpace(PC), a0
00601168  6100 0362               1229      bsr.w   putString
0060116C  41F9 000FF800           1230      lea     msgASCIIDump, a0
00601172                          1231  .dr_2:
00601172  1019                    1232      move.b  (a1)+, d0       * Read a byte from RAM
00601174  6100 0330               1233      bsr.w   writeByte       * display byte as 2 hex digits  
00601178  6100 004A               1234      bsr.w   makePrintable   * convert to printable character
0060117C  10C0                    1235      move.b  d0,(a0)+        * save the printable char in output string
0060117E  103C 0020               1236      move.b  #' ', d0
00601182  6100 038E               1237      bsr.w   putCh           * insert a space
00601186  51CA FFEA               1238      dbra    d2,.dr_2
0060118A                          1239  
0060118A  103C 0020               1240      move.b  #' ', d0
0060118E  6100 0382               1241      bsr.w   putCh           * insert a space
00601192                          1242  
00601192  10FC 000D               1243      move.b  #ASCII_CR,(a0)+
00601196  10FC 000A               1244      move.b  #ASCII_LF,(a0)+
0060119A  10FC 0000               1245      move.b  #0,(a0)+
0060119E  41F9 000FF800           1246      lea     msgASCIIDump, a0
006011A4  6100 0326               1247      bsr.w   putString       * print out the printable bytes
006011A8  51C9 FFB0               1248      dbra    d1,.dr_1
006011AC                          1249  
006011AC  4CDF 0207               1250      movem.l (SP)+, d0-d2/a1 * Restore registers
006011B0  4E75                    1251      rts
006011B2                          1252              
006011B2                          1253  *------------------------------------------------------------------------------
006011B2                          1254  * Convert character in D0 to upper case
006011B2                          1255  * Only changes D0 if char is between 'a'..'z'
006011B2                          1256  *------------------------------------------------------------------------------
006011B2                          1257  chToUpper:
006011B2  B03C 0061               1258      cmp.b   #'a', d0         
006011B6  6D0A                    1259      blt.s   .done            * less than lower-case 'a' so leave alone
006011B8  B03C 007A               1260      cmp.b   #'z', d0
006011BC  6E04                    1261      bgt.s   .done            * greater than lower-case 'z' so leave alone
006011BE  0400 0020               1262      sub.b   #$20, d0         * convert to upper case
006011C2                          1263  .done:
006011C2  4E75                    1264      rts
006011C4                          1265      
006011C4                          1266  *------------------------------------------------------------------------------
006011C4                          1267  * Convert a byte into a print safe character
006011C4                          1268  * Substitute a '.' for any byte <32 or >126
006011C4                          1269  * D0 holds the byte
006011C4                          1270  *------------------------------------------------------------------------------
006011C4                          1271  makePrintable:
006011C4  B03C 0020               1272      cmp.b   #' ', d0         
006011C8  6D06                    1273      blt.s   .mp_1           * less than a SPACE (char 32)
006011CA                          1274  
006011CA  B03C 007E               1275      cmp.b   #'~', d0         
006011CE  6F04                    1276      ble.s   .mp_x           * less than a DEL (char 127)
006011D0                          1277  
006011D0                          1278  .mp_1:
006011D0  103C 002E               1279      move.b  #'.',d0         * substitute a DOT (char 46)
006011D4                          1280  .mp_x:
006011D4  4E75                    1281      rts
006011D6                          1282      
006011D6                          1283  *--------------------------------------------------------------------------
006011D6                          1284  * Read in an ASCII-HEX number - no echo back
006011D6                          1285  *
006011D6                          1286  * D2 = Value to return if no digits read in
006011D6                          1287  * D1 = Max no of ASCII digits to read in
006011D6                          1288  * D0 = Result
006011D6                          1289  * Carry flag set if an error occurs / not ASCII-HEX digit
006011D6                          1290  *--------------------------------------------------------------------------
006011D6                          1291  hexToInt:
006011D6                          1292  *   move.l  d2,-(SP)        * save D2
006011D6                          1293  *   clr.l   d2              * D2 used to accumulate the final value
006011D6                          1294  .h2i_1:
006011D6  6100 035C               1295      bsr.w   getCh           * get a character
006011DA  61D6                    1296      bsr.s   chToUpper       * convert to upper case if needed
006011DC                          1297  
006011DC  0C00 000A               1298      cmpi.b  #10,d0          * finish if it's CR or LF
006011E0  6724                    1299      beq.s   .h2i_x
006011E2  0C00 000D               1300      cmpi.b  #13,d0
006011E6  671E                    1301      beq.s   .h2i_x
006011E8                          1302      
006011E8  0400 0030               1303      subi.b  #'0',d0
006011EC  6B1C                    1304      bmi.s   .h2i_err        * quit if char is less than '0'
006011EE                          1305  
006011EE  0C00 0009               1306      cmpi.b  #9,d0
006011F2  6F0A                    1307      ble.s   .h2i_2          * is it <= 9
006011F4                          1308      
006011F4  5F00                    1309      subi.b  #7,d0
006011F6  6B12                    1310      bmi.s   .h2i_err        * quit if char is >'9' and <'A'
006011F8                          1311  
006011F8  0C00 000F               1312      cmpi.b  #15,d0
006011FC  6E0C                    1313      bgt.s   .h2i_err        * quit if char is >'F'
006011FE                          1314  
006011FE                          1315  .h2i_2:
006011FE  E98A                    1316      lsl.l   #4, d2
00601200  8400                    1317      or.b    d0, d2          * insert the new digit
00601202                          1318  
00601202  5301                    1319      subq.b  #1, d1          * decrement the digit count
00601204  66D0                    1320      bne.s   .h2i_1          * go back for another digit?
00601206                          1321  
00601206                          1322  .h2i_x:
00601206  2002                    1323      move.l  d2,d0           * put the answer back into D0
00601208                          1324  *   move.l  (SP)+,d2        * restore D2
00601208  4E75                    1325      rts
0060120A                          1326  
0060120A                          1327  .h2i_err:
0060120A                          1328  *   move.l  (SP)+,d2        * restore D2
0060120A  003C 0001               1329      ori.b   #1,CCR          * set the CARRY flag to signal an error
0060120E  4E75                    1330      rts
00601210                          1331  
00601210                          1332  *--------------------------------------------------------------------------
00601210                          1333  * Read in an ASCII-HEX number with echo back
00601210                          1334  *
00601210                          1335  * D2 = Value to return if no digits read in
00601210                          1336  * D1 = Max no of ASCII digits to read in
00601210                          1337  * D0 = Result
00601210                          1338  * Carry flag set if an error occurs / not ASCII-HEX digit
00601210                          1339  *--------------------------------------------------------------------------
00601210                          1340  hexToIntEcho:
00601210                          1341  *   move.l  d2,-(SP)        * save D2
00601210                          1342  *   clr.l   d2              * D2 used to accumulate the final value
00601210                          1343  .h2i_1:
00601210  6100 0322               1344      bsr.w   getCh           * get a character
00601214  6100 02FC               1345      bsr.w   putCh           * echo it back
00601218  6198                    1346      bsr.s   chToUpper       * convert to upper case if needed
0060121A                          1347  
0060121A  0C00 000A               1348      cmpi.b  #10,d0          * finish if it's CR or LF
0060121E  6724                    1349      beq.s   .h2i_x
00601220  0C00 000D               1350      cmpi.b  #13,d0
00601224  671E                    1351      beq.s   .h2i_x
00601226                          1352      
00601226  0400 0030               1353      subi.b  #'0',d0
0060122A  6B1C                    1354      bmi.s   .h2i_err        * quit if char is less than '0'
0060122C                          1355  
0060122C  0C00 0009               1356      cmpi.b  #9,d0
00601230  6F0A                    1357      ble.s   .h2i_2          * is it <= 9
00601232                          1358      
00601232  5F00                    1359      subi.b  #7,d0
00601234  6B12                    1360      bmi.s   .h2i_err        * quit if char is >'9' and <'A'
00601236                          1361  
00601236  0C00 000F               1362      cmpi.b  #15,d0
0060123A  6E0C                    1363      bgt.s   .h2i_err        * quit if char is >'F'
0060123C                          1364  
0060123C                          1365  .h2i_2:
0060123C  E98A                    1366      lsl.l   #4, d2
0060123E  8400                    1367      or.b    d0, d2          * insert the new digit
00601240                          1368  
00601240  5301                    1369      subq.b  #1, d1          * decrement the digit count
00601242  66CC                    1370      bne.s   .h2i_1          * go back for another digit?
00601244                          1371  
00601244                          1372  .h2i_x:
00601244  2002                    1373      move.l  d2,d0           * put the answer back into D0
00601246                          1374  *   move.l  (SP)+,d2        * restore D2
00601246  4E75                    1375      rts
00601248                          1376  
00601248                          1377  .h2i_err:
00601248                          1378  *   move.l  (SP)+,d2        * restore D2
00601248  003C 0001               1379      ori.b   #1,CCR          * set the CARRY flag to signal an error
0060124C  4E75                    1380      rts
0060124E                          1381  
0060124E                          1382  *------------------------------------------------------------------------------
0060124E                          1383  * ReadHexByte - read two ASCII hex chars at (A0)+
0060124E                          1384  * Uses: D1
0060124E                          1385  * Ret:  D0 = binary byte
0060124E                          1386  *------------------------------------------------------------------------------
0060124E                          1387  ReadHexByte:
0060124E  1218                    1388      move.b  (a0)+, d1
00601250  6100 0010               1389      bsr     HexCharToNibble
00601254  E148                    1390      lsl.w   #8, d0          * save nibble in bits 8..11
00601256  1218                    1391      move.b  (a0)+, d1
00601258  6100 0008               1392      bsr     HexCharToNibble
0060125C  E908                    1393      lsl.b   #4, d0          * shift nibble into bits 4..7
0060125E  E848                    1394      lsr.w   #4, d0          * shift whole byte into bits 0..7
00601260  4E75                    1395      rts
00601262                          1396  
00601262                          1397  *------------------------------------------------------------------------------
00601262                          1398  * HexCharToNibble - convert ASCII hex char in D1 to nibble
00601262                          1399  * Ret:  D0 = converted char
00601262                          1400  *------------------------------------------------------------------------------
00601262                          1401  HexCharToNibble:
00601262  1001                    1402      move.b  d1, d0          * move char to D0
00601264  B03C 0030               1403      cmp.b   #'0', d0        * compare with ASCII char '0'
00601268  6D38                    1404      blt.s   .HexError       * error if it's less than '0'
0060126A  B03C 0039               1405      cmp.b   #'9', d0        * compare with ASCII char '9'
0060126E  6F2C                    1406      ble.s   .IsDigit        * it's a digit if less than '9'
00601270  B03C 0041               1407      cmp.b   #'A', d0        * compare with ASCII char 'A'
00601274  6D2C                    1408      blt.s   .HexError       * error if it's less than 'A'
00601276  B03C 0046               1409      cmp.b   #'F', d0        * compare with ASCII char 'F'
0060127A  6F16                    1410      ble.s   .IsUpper        * it's between 'A' and 'F'
0060127C  B03C 0061               1411      cmp.b   #'a', d0        * compare with ASCII char 'a'
00601280  6D20                    1412      blt.s   .HexError       * error if it's less than 'a'
00601282  B03C 0066               1413      cmp.b   #'f', d0        * compare with ASCII char 'f'
00601286  6E1A                    1414      bgt.s   .HexError       * error if it's greater than 'f'
00601288  0400 0061               1415      sub.b   #'a', d0
0060128C  0600 000A               1416      add.b   #10, d0
00601290  4E75                    1417      rts
00601292                          1418  .IsUpper:
00601292  0400 0041               1419      sub.b   #'A', d0
00601296  0600 000A               1420      add.b   #10, d0
0060129A  4E75                    1421      rts
0060129C                          1422  .IsDigit:
0060129C  0400 0030               1423      sub.b   #'0', d0
006012A0  4E75                    1424      rts
006012A2                          1425  .HexError:
006012A2  7000                    1426      moveq   #0, d0
006012A4  4E75                    1427      rts
006012A6                          1428  
