0060007C= 006005C6                 343      DC.L    handleAV7      *1F Level 7 Interrupt Autovector
00600080= 006005D2                 344      DC.L    handleTrap0    *20 TRAP #0  Instruction Vector
00600084= 006005DE                 345      DC.L    handleTrap1    *21 TRAP #1  Instruction Vector
00600088= 006005EA                 346      DC.L    handleTrap2    *22 TRAP #2  Instruction Vector
0060008C= 006005F6                 347      DC.L    handleTrap3    *23 TRAP #3  Instruction Vector
00600090= 00600602                 348      DC.L    handleTrap4    *24 TRAP #4  Instruction Vector
00600094= 0060060E                 349      DC.L    handleTrap5    *25 TRAP #5  Instruction Vector
00600098= 0060061A                 350      DC.L    handleTrap6    *26 TRAP #6  Instruction Vector
0060009C= 00600626                 351      DC.L    handleTrap7    *27 TRAP #7  Instruction Vector
006000A0= 00600632                 352      DC.L    handleTrap8    *28 TRAP #8  Instruction Vector
006000A4= 0060063E                 353      DC.L    handleTrap9    *29 TRAP #9  Instruction Vector
006000A8= 0060064A                 354      DC.L    handleTrap10   *2A TRAP #10 Instruction Vector
006000AC= 00600656                 355      DC.L    handleTrap11   *2B TRAP #11 Instruction Vector
006000B0= 00600662                 356      DC.L    handleTrap12   *2C TRAP #12 Instruction Vector
006000B4= 0060066E                 357      DC.L    handleTrap13   *2D TRAP #13 Instruction Vector
006000B8= 0060067A                 358      DC.L    handleTrap14   *2E TRAP #14 Instruction Vector
006000BC= 00601388                 359      DC.L    easy68kTrap15  *2F TRAP #15 Instruction Vector
006000C0                           360  
006000C0                           361  *------------------------------------------------------------------------------
006000C0                           362  * Exception Vectors 30 to 7F are not used on my system so just point them
006000C0                           363  * all to the default handler.
006000C0                           364  
006000C0= 00600692 00600692 ...    365      DCB.L   80,handleUnused
00600200                           366  
00600200                           367  *------------------------------------------------------------------------------
00600200                           368  * The MC68302 GIMR should have the V7-V5 bits set to 100 so that the MC68302
00600200                           369  * internal peripherals will use exception vectors $80 to $97.
00600200                           370  
00600200= 00600692                 371      DC.L    handleUnused        *80 Error
00600204= 00600692                 372      DC.L    handleUnused        *81 General purpose interrupt #0 (PB8)
00600208= 00600692                 373      DC.L    handleUnused        *82 SMC2
0060020C= 00600692                 374      DC.L    handleUnused        *83 SMC1
00600210= 00600692                 375      DC.L    handleUnused        *84 Timer 3
00600214= 00600692                 376      DC.L    handleUnused        *85 SCP
00600218= 00600692                 377      DC.L    handleUnused        *86 Timer 2
0060021C= 00600692                 378      DC.L    handleUnused        *87 General purpose interrupt #1 (PB9)
00600220= 00600692                 379      DC.L    handleUnused        *88 SCC3
00600224= 00600692                 380      DC.L    handleUnused        *89 Timer 1
00600228= 00600692                 381      DC.L    handleUnused        *8A SCC2
0060022C= 00600692                 382      DC.L    handleUnused        *8B IDMA
00600230= 00600692                 383      DC.L    handleUnused        *8C SDMA BErr
00600234= 00600692                 384      DC.L    handleUnused        *8D SCC1
00600238= 00600692                 385      DC.L    handleUnused        *8E General purpose interrupt #2 (PB10)
0060023C= 00600692                 386      DC.L    handleUnused        *8F General purpose interrupt #3 (PB11)
00600240= 00600692                 387      DC.L    handleUnused        *90 (Unassigned)
00600244= 00600692                 388      DC.L    handleUnused        *91 External Device
00600248= 00600692                 389      DC.L    handleUnused        *92 (Unassigned)
0060024C= 00600692                 390      DC.L    handleUnused        *93 (Unassigned)
00600250= 00600692                 391      DC.L    handleUnused        *94 (Unassigned)
00600254= 00600692                 392      DC.L    handleUnused        *95 (Unassigned)
00600258= 00600692                 393      DC.L    handleUnused        *96 External Device
0060025C= 00600692                 394      DC.L    handleUnused        *97 External Device
00600260                           395  
00600260                           396  *------------------------------------------------------------------------------
00600260                           397  * Interrupt Vectors $98 to $FF are not used on my system so just point them
00600260                           398  * all to the default handler.
00600260                           399  
00600260= 00600692 00600692 ...    400      DCB.L   104,handleUnused
00600400                           401  
00600400                           402  *******************************************************************************
00600400                           403  *
00600400                           404  *   #####  ####### #       ######            #####  #######    #    ######  ####### 
00600400                           405  *  #     # #     # #       #     #          #     #    #      # #   #     #    #    
00600400                           406  *  #       #     # #       #     #          #          #     #   #  #     #    #    
00600400                           407  *  #       #     # #       #     #           #####     #    #     # ######     #    
00600400                           408  *  #       #     # #       #     #                #    #    ####### #   #      #    
00600400                           409  *  #     # #     # #       #     #          #     #    #    #     # #    #     #    
00600400                           410  *   #####  ####### ####### ######            #####     #    #     # #     #    #    
00600400                           411  *
00600400                           412  *******************************************************************************
00600400                           413  * This code needs to go immediately after the exception vector table so that it
00600400                           414  * lies within the first 8K of the ROM.
00600400                           415  *
00600400                           416  * NOTE: RAM is not accessible until BR1 and OR1 are both programmed.
00600400                           417  *******************************************************************************
00600400                           418  
00600400                           419      ORG     (*+1)&-2                    * make sure we start on a word aligned address
00600400                           420  START:
00600400  46FC 2700                421      move.w  #$2700,sr                   * mask off all interrupts
00600404  31FC 0FFF 00F2           422      move.w  #(M302_BASE_ADDR>>12),M302_BAR      * 68302 BAR points to 0xFFF000
0060040A  2E7C 00FFF240            423      move.l  #(M302_BASE_ADDR+$240),sp   * initial stack at top of 68302 user RAM
00600410                           424  
00600410                           425      * Base Register 0 (BR0) and Option Register 0 (OR0) default to mapping /CS0
00600410                           426      * for an 8K block of memory starting at address 0x000000. This should be
00600410                           427      * enough for what we need to do to reconfigure the ROM and RAM addresses.
00600410                           428  
00600410                           429      * Configure Base Register 1 (BR1) and Option Register 1 (OR1) for /CS1
00600410                           430      * (i.e. the RAM) to be a 1MB block starting at ROM_BASE (yes, ROM_BASE!)
00600410                           431      * so that RAM is located where the ROM will be after the swap.
00600410  33FC 0C01 00FFF834       432      move.w  #CS0_BR,M302_BR1        * Base Register 1
00600418  33FC 1E00 00FFF836       433      move.w  #CS0_OR,M302_OR1        * Option Register 1
00600420                           434  
00600420                           435      * ROM (/CS0) is now at 0x000000 (default at reset) and RAM (/CS1) will
00600420                           436      * start at ROM_BASE.
00600420                           437    
00600420                           438      * NOTE: Disable the function code comparison first otherwise you can't copy
00600420                           439      * code and data from the ROM.
00600420  0279 FFFE 00FFF832       440      andi.w  #$FFFE,M302_OR0
00600428                           441  
00600428                           442  *------------------------------------------------------------------------------
00600428                           443  * Copy the exception vector table from ROM to RAM
00600428                           444  * The swap hasn't happened yet so ROM is at 0x000000 (i.e. RAM_BASE) and RAM
00600428                           445  * starts at ROM_BASE!
00600428                           446  *------------------------------------------------------------------------------
00600428                           447  
00600428  207C 00000000            448      movea.l #$000000,a0             * A0 = start address of ROM
0060042E  227C 00600000            449      movea.l #ROM_BASE,a1            * A1 = start address of RAM before the swap
00600434  323C 00FF                450      move.w  #255,d1                 * D0 = number of longwords to copy - 256 but
00600438                           451                                      * DBRA needs 1 count less
00600438                           452  .vtcopy:
00600438  22D8                     453      move.l  (a0)+,(a1)+             * copy the bytes from ROM to RAM
0060043A  51C9 FFFC                454      dbra    d1,.vtcopy  
0060043E                           455  
0060043E                           456  *------------------------------------------------------------------------------
0060043E                           457  * Copy the ROM & RAM address swap code into the 68302 Dual Port RAM
0060043E                           458  * A0 holds the start address of the swap code in ROM when the ROM is mapped to
0060043E                           459  * address 0x000000 - i.e. on startup.
0060043E                           460  *------------------------------------------------------------------------------
0060043E                           461  
0060043E  207C 0000045C            462      movea.l #dprCodeStart-ROM_BASE,a0
00600444  227C 00FFF000            463      movea.l #M302_BASE_ADDR,a1  * A1 = start address of the 68302 DP RAM
0060044A  243C 00000026            464      move.l  #DPR_CODE_LEN,d2    * D2 = number of bytes to copy
00600450                           465  .swcopy:
00600450  12D8                     466      move.b  (a0)+,(a1)+         * copy the byte from EEROM to DP RAM
00600452  51CA FFFC                467      dbra    d2,.swcopy
00600456                           468  
00600456                           469  *------------------------------------------------------------------------------
00600456                           470  * The switching code is now in DP RAM inside the 68302 so jump to it to perform
00600456                           471  * the switch.
00600456                           472  *------------------------------------------------------------------------------
00600456                           473  
00600456  4EF9 00FFF000            474      jmp     (M302_BASE_ADDR).L
0060045C                           475  
0060045C                           476  *------------------------------------------------------------------------------
0060045C                           477  * This is the code that remaps the ROM and RAM addresses. It should be copied
0060045C                           478  * into the start of Dual Port RAM of the 68302 (i.e. M302_BASE_ADDR defined in
0060045C                           479  * mc68302.inc)
0060045C                           480  *------------------------------------------------------------------------------
0060045C                           481  dprCodeStart:
0060045C  33FC 0C01 00FFF830       482      move.w  #CS0_BR,M302_BR0        * Base Register 0
00600464  33FC 1E00 00FFF832       483      move.w  #CS0_OR,M302_OR0        * Option Register 0
0060046C                           484  
0060046C  33FC 0001 00FFF834       485      move.w  #CS1_BR,M302_BR1        * Base Register 1
00600474  33FC 1E00 00FFF836       486      move.w  #CS1_OR,M302_OR1        * Option Register 1
0060047C                           487  
0060047C                           488      * the ROM on CS0 is now mapped to start at address ROM_BASE
0060047C                           489      * and the RAM on CS1 is now mapped to start at RAM_BASE (i.e. 0x000000)
0060047C                           490      * so now return to the ROM code at its proper address.
0060047C  4EF9 00600482            491      jmp     (dprReturn).L
00600482                           492      
00600482  =00000026                493  DPR_CODE_LEN    EQU *-dprCodeStart
00600482                           494  
00600482                           495  *------------------------------------------------------------------------------
00600482                           496  * Jump back to here from the switching code in the 68302 DP RAM.
00600482                           497  * RAM should now be available from 0x000000 to RAM_LEN and the ROM should be
00600482                           498  * positioned correctly starting at ROM_BASE.
00600482                           499  *------------------------------------------------------------------------------
00600482                           500  dprReturn:
00600482                           501      * setup the MC68302 chip select #2 for 128K of RCBus
00600482  33FC 5FC0 00FFF83A       502      move.w  #(CS2_OR|$4000),M302_OR2    * DTACK after 2 wait states
0060048A  33FC 1F81 00FFF838       503      move.w  #(CS2_BR|$0001),M302_BR2    * enable CS2
00600492                           504  
00600492                           505  *------------------------------------------------------------------------------
00600492                           506  * Configure the 68302 interrupts
00600492                           507  *------------------------------------------------------------------------------
00600492                           508  
00600492  33FC 0080 00FFF812       509      move.w  #$80,M302_GIMR          * normal mode, vectors 80+
0060049A  33FC 0000 00FFF816       510      move.w  #0,M302_IMR             * no interrupts
006004A2  33FC FFFF 00FFF814       511      move.w  #$FFFF,M302_IPR         * clear pending interrupts
006004AA  33FC FFFF 00FFF818       512      move.w  #$FFFF,M302_ISR         * clear in-service
006004B2                           513  
006004B2                           514      * make sure that the stack pointer is initialised
006004B2  4FF9 000FF800            515      lea     STACK_START,sp
006004B8                           516  
006004B8                           517      * configure SCC1
006004B8  6100 0EEE                518      bsr     SCC1Init
006004BC                           519  
006004BC                           520  *******************************************************************************
006004BC                           521  * The 68302 should now be set up with ROM and RAM at their correct addresses
006004BC                           522  * in the memory space. Jump to the monitor code from here.
006004BC                           523  *******************************************************************************
006004BC                           524  
006004BC  4EF9 00600EC2            525      jmp     (monStart).L
006004C2                           526  
006004C2                           527  *******************************************************************************
006004C2                           528  * Below are the actual exception handlers that are accessed from the vector
006004C2                           529  * table in RAM. The user can overwrite any of the RAM vector table addresses
006004C2                           530  * with the address of their own exception handler. These handlers simply output
006004C2                           531  * a message to the serial port and enter an endless loop.
006004C2                           532  *******************************************************************************
006004C2                           533  
006004C2                           534  *------------------------------------------------------------------------------
006004C2                           535  * BUS ERROR handler
006004C2                           536  * Print a message showing the PC and address being accessed
006004C2                           537  *------------------------------------------------------------------------------
006004C2                           538  handleBusErr:
006004C2  41FA 0402                539      lea     bemsg1(PC), a0  * first message
006004C6  6100 1004                540      bsr.w   putString
006004CA  202F 000A                541      move.l  10(a7),d0       * get the program counter 
006004CE  6100 0FB8                542      bsr.w   writeAddr32
006004D2                           543      
006004D2  41FA 0431                544      lea     bemsg2(PC), a0  * second message
006004D6  6100 0FF4                545      bsr.w   putString
006004DA  6000 01C2                546      bra.w   handleCleanUp
006004DE                           547      
006004DE                           548  *------------------------------------------------------------------------------
006004DE                           549  * ADDRESS ERROR handler
006004DE                           550  * Print a message showing the PC and address being accessed
006004DE                           551  *------------------------------------------------------------------------------
006004DE                           552  handleAddrErr:
006004DE  41FA 01CC                553      lea     aemsg1(PC), a0  * first message
006004E2  6100 0FE8                554      bsr.w   putString
006004E6  202F 000A                555      move.l  10(a7),d0       * get the program counter 
006004EA  6100 0F9C                556      bsr.w   writeAddr32
006004EE                           557      
006004EE  41FA 0200                558      lea     aemsg2(PC), a0  * second message
006004F2  6100 0FD8                559      bsr.w   putString
006004F6  6000 01A6                560      bra.w   handleCleanUp
006004FA                           561      
006004FA                           562  *------------------------------------------------------------------------------
006004FA                           563  * ILLEGAL INSTRUCTION handler
006004FA                           564  *------------------------------------------------------------------------------
006004FA                           565  handleIllInst:
006004FA  41FA 0468                566      lea     iimsg(PC), a0   * display message
006004FE  6100 0FCC                567      bsr.w   putString
00600502  6000 019A                568      bra.w   handleCleanUp
00600506                           569      
00600506                           570  *------------------------------------------------------------------------------
