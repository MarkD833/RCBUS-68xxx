00600028= 00600542                 322      DC.L    handleLineA    *0A Line 1010 Emulator
0060002C= 0060054E                 323      DC.L    handleLineF    *0B Line 1111 Emulator
00600030= 0060055A                 324      DC.L    handleRes1     *0C (Unassigned, Reserved)
