00601332                          1506  *------------------------------------------------------------------------------
00601332                          1507  * EASy68K TRAP #15 - Task 0
00601332                          1508  * Display n characters of string at (A1), n is D1.W (stops on NULL or max 255) with CR, LF.
00601332                          1509  *------------------------------------------------------------------------------
00601332                          1510  easyTask0:
00601332  0241 00FF               1511      andi.w  #$00FF,d1   * DBRA works on a WORD so make sure upper byte is zero
00601336  5301                    1512      sub.b   #1,d1       * DBRA requires 1 less than actual number
00601338                          1513  .loop:
00601338  1019                    1514      move.b  (a1)+, d0    * Read in character
0060133A  6708                    1515      beq.s   .end         * Check for the null
0060133C                          1516      
0060133C  6100 01D4               1517      bsr.w   putCh        * Otherwise write the character
00601340  51C9 FFF6               1518      dbra    d1,.loop     * And continue
00601344                          1519  .end:
00601344  6100 0182               1520      bsr.w   putCRLF     * append CR & LF
00601348  4E75                    1521      rts
0060134A                          1522  
0060134A                          1523  *------------------------------------------------------------------------------
0060134A                          1524  * EASy68K TRAP #15 - Task 1
0060134A                          1525  * Display n characters of string at (A1), n is D1.W (stops on NULL or max 255) without CR, LF.
0060134A                          1526  *------------------------------------------------------------------------------
0060134A                          1527  easyTask1:
0060134A  0241 00FF               1528      andi.w  #$00FF,d1   * DBRA works on a WORD so make sure upper byte is zero
0060134E  5301                    1529      sub.b   #1,d1       * DBRA requires 1 less than actual number
00601350                          1530  .loop:
00601350  1019                    1531      move.b  (a1)+, d0    * Read in character
00601352  6708                    1532      beq.s   .end         * Check for the null
00601354                          1533      
00601354  6100 01BC               1534      bsr.w   putCh        * Otherwise write the character
00601358  51C9 FFF6               1535      dbra    d1,.loop     * And continue
0060135C                          1536  .end:
0060135C  4E75                    1537      rts
0060135E                          1538  
0060135E                          1539  *------------------------------------------------------------------------------
0060135E                          1540  * EASy68K TRAP #15 - Task 5
0060135E                          1541  * Read single ASCII character from the keyboard into D1.B. 
0060135E                          1542  *------------------------------------------------------------------------------
0060135E                          1543  easyTask5:
0060135E  6100 01D4               1544      bsr.w   getCh       * wait for char - returned in D0
00601362  1200                    1545      move.b  d0,d1       * move the char into D1
00601364  4E75                    1546      rts
00601366                          1547      
00601366                          1548  *------------------------------------------------------------------------------
00601366                          1549  * EASy68K TRAP #15 - Task 6
00601366                          1550  * Display single ASCII character in D1.B.   
00601366                          1551  *------------------------------------------------------------------------------
00601366                          1552  easyTask6:
00601366  1001                    1553      move.b  d1,d0       * move the char into D0
00601368  6100 01A8               1554      bsr.w   putCh       * output the char
0060136C  4E75                    1555      rts
0060136E                          1556  
0060136E                          1557  *------------------------------------------------------------------------------
0060136E                          1558  * EASy68K TRAP #15 - Task 7
0060136E                          1559  * Check for keyboard input. Set D1.B to 1 if keyboard input is pending,
0060136E                          1560  * otherwise set to 0.
0060136E                          1561  *------------------------------------------------------------------------------
0060136E                          1562  easyTask7:
0060136E  6100 0224               1563      bsr.w   chkCh
00601372  4E75                    1564      rts
