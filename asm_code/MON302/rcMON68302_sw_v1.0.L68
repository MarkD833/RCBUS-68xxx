00601388                          1585  *------------------------------------------------------------------------------
00601388                          1586  * This is the entry point for the TRAP #15 handler that gets called when any
00601388                          1587  * TRAP #15 services are required. Only a few tasks are implemented.
00601388                          1588  * Unimplemented tasks will produce an error message.
00601388                          1589  *------------------------------------------------------------------------------
00601388                          1590  easy68kTrap15:
00601388  48E7 10A0               1591      movem.l d3/a0/a2,-(sp)
0060138C  45FA FF18               1592      lea     easy68kTaskTable(PC),a2
00601390  B03C 0019               1593      cmp.b   #25,d0          ; is task number greater than 25?
00601394  6E00 FF78               1594      bgt     easyTaskUnsupported
00601398                          1595      
00601398  4283                    1596      clr.l   d3
0060139A  1600                    1597      move.b  d0,d3           ; task number into D3
0060139C  E58B                    1598      lsl.l   #2,d3           ; convert task number into longword offset
0060139E  4EB2 3000               1599      jsr     (a2,d3)         ; jump to the specific task handler
006013A2                          1600      
006013A2  4CDF 0508               1601      movem.l (sp)+,d3/a0/a2
006013A6  4E73                    1602      rte
006013A8                          1603  
006013A8                          1604  *--------------------------------------------------------------------------
006013A8                          1605  * Initialise SCC1 as a UART - Section E.2 of the 68302UM
006013A8                          1606  * Uses 1 Tx buffer and 2 Rx buffers, all held in external RAM.
006013A8                          1607  * Baud rate is set by SER1_BAUD defined at the top of this file.
006013A8                          1608  * Tx and Rx buffer sizes are set by SER1_BUFSIZE defined at the top of this file.
006013A8                          1609  *
006013A8                          1610  * NOTE:
006013A8                          1611  * An Rx buffer will become ready for reading if:
006013A8                          1612  * - A special character is received
006013A8                          1613  * - Max characters received - set by value in MRBLR registers
006013A8                          1614  * - A gap between characters received greater than MAXIDL
006013A8                          1615  *--------------------------------------------------------------------------
006013A8                          1616  SCC1Init:
006013A8  33FC 00C0 00FFF8B4      1617      move.w  #$00C0,M302_SIMODE
006013B0  33FC 0016 00FFF882      1618      move.w  #(SER1_BAUD<<1),M302_SCON1  * set SCC1 baud rate
006013B8  33FC 0101 00FFF884      1619      move.w  #$0101,M302_SCM1                * set SCC1 to UART mode 8N1
006013C0                          1620  
006013C0                          1621      * TxBD0 in internal RAM
006013C0  33FC 2000 00FFF440      1622      move.w  #$2000,M302_SCC1PB+M302_TXBD0       * INT RAM - first and only tx buffer
006013C8  33FC 0000 00FFF442      1623      move.w  #$0000,M302_SCC1PB+M302_TXBD0+2 * no bytes in tx buffer
006013D0  23FC 00FFF000 00FFF444  1624      move.l  #SCC1TXB0,M302_SCC1PB+M302_TXBD0+4
006013DA                          1625  
006013DA                          1626      * RxBD0 in internal RAM
006013DA  33FC 8000 00FFF400      1627      move.w  #$8000,M302_SCC1PB+M302_RXBD0       * first rx buffer
006013E2  23FC 00FFF080 00FFF404  1628      move.l  #SCC1RXB0,M302_SCC1PB+M302_RXBD0+4
006013EC                          1629  
006013EC                          1630      * RxBD1 in internal RAM
006013EC  33FC A000 00FFF408      1631      move.w  #$A000,M302_SCC1PB+M302_RXBD1       * second and final rx buffer
006013F4  23FC 00FFF100 00FFF40C  1632      move.l  #SCC1RXB1,M302_SCC1PB+M302_RXBD1+4
006013FE                          1633  
006013FE  13FC 0020 00FFF480      1634      move.b  #$20,M302_SCC1PB+M302_RFCR
00601406  13FC 0020 00FFF481      1635      move.b  #$20,M302_SCC1PB+M302_TFCR
0060140E                          1636      
0060140E                          1637      * set the max rx buffer length to slightly less than the actual max size
0060140E  33FC 007C 00FFF482      1638      move.w  #SER1_BUFSIZE-4,M302_SCC1PB+M302_MRBLR
00601416                          1639      
00601416                          1640      * set MAXIDL to about 10mS - i.e. the time taken for 38 chars @ 38400 baud
00601416                          1641      * if another char isn't received within 10mS, then buffer will be closed 
00601416  33FC 0026 00FFF49C      1642      move.w  #38,M302_SCC1PB+M302_MAXIDL     * set MAXIDL to a small value
0060141E                          1643      
0060141E  33FC 0000 00FFF4A0      1644      move.w  #0,M302_SCC1PB+M302_BRKCR           * no BREAK characters
00601426                          1645      
00601426  33FC 0000 00FFF4A2      1646      move.w  #0,M302_SCC1PB+M302_PAREC           * reset PARITY ERROR counter
0060142E  33FC 0000 00FFF4A4      1647      move.w  #0,M302_SCC1PB+M302_FRMEC           * reset FRAME ERROR counter
00601436  33FC 0000 00FFF4A6      1648      move.w  #0,M302_SCC1PB+M302_NOSEC           * reset NOISE counter
0060143E  33FC 0000 00FFF4A8      1649      move.w  #0,M302_SCC1PB+M302_BRKEC           * reset BREAK counter
00601446                          1650      
00601446  33FC 0000 00FFF4AA      1651      move.w  #0,M302_SCC1PB+M302_UADDR1      * clear UART adress characters
0060144E  33FC 0000 00FFF4AC      1652      move.w  #0,M302_SCC1PB+M302_UADDR2
00601456                          1653  
00601456  33FC 000D 00FFF4B0      1654      move.w  #$000D,M302_SCC1PB+M302_CCHAR1  * CR is a special character
0060145E  33FC 8000 00FFF4B2      1655      move.w  #$8000,M302_SCC1PB+M302_CCHAR2  * no more special characters
00601466  33FC 0000 00FFF4BE      1656      move.w  #0,M302_SCC1PB+M302_CCHAR8
0060146E                          1657      
0060146E  13FC 00FF 00FFF888      1658      move.b  #$FF,M302_SCCE1              * clear any SCC1 events
00601476  13FC 0000 00FFF88A      1659      move.b  #0,M302_SCCM1                * no interrupts from SCC1
0060147E  0079 000C 00FFF884      1660      ori.w   #$000C,M302_SCM1                * enable SCC1 Tx & Rx
00601486                          1661  
00601486  4E75                    1662      rts
00601488                          1663      
00601488                          1664  *==============================================================================
00601488                          1665  * These are the various printing routines that handle displaying of bytes,
00601488                          1666  * words, long words and 24-bit values as ASCII hexadecimal text. The routines
00601488                          1667  * must be kept in this order as program flow is meant to fall out of one
00601488                          1668  * routine and into the next, often without a return statement.
00601488                          1669  *==============================================================================
00601488                          1670  
00601488                          1671  *------------------------------------------------------------------------------
00601488                          1672  * Output a 32-bit address as 8 ASCII hexadecimal digits
00601488                          1673  * D0 holds the 32-bit address
00601488                          1674  *------------------------------------------------------------------------------
00601488                          1675  writeAddr32:
00601488  2F00                    1676      move.l  d0,-(sp)    ; save D0 first
0060148A  E098                    1677      ror.l   #8,d0
0060148C  E098                    1678      ror.l   #8,d0
0060148E  610E                    1679      bsr.s   writeWord   ; write bits 16..31
00601490  201F                    1680      move.l  (sp)+,d0    ; restore D0
00601492  600A                    1681      bra.s   writeWord
00601494                          1682      
00601494                          1683  *------------------------------------------------------------------------------
00601494                          1684  * Output a 24-bit address as 6 ASCII hexadecimal digits
00601494                          1685  * D0 holds the address in bits 0..23
00601494                          1686  * NOTE: the writeWord function must be directly after this function
00601494                          1687  *------------------------------------------------------------------------------
00601494                          1688  writeAddr24:
00601494  2F00                    1689      move.l  d0,-(sp)    ; save D0 first
00601496  E098                    1690      ror.l   #8,d0
00601498  E098                    1691      ror.l   #8,d0
0060149A  610A                    1692      bsr.s   writeByte   ; write bits 16..23
0060149C  201F                    1693      move.l  (sp)+,d0    ; restore D0
0060149E                          1694      
0060149E                          1695  *------------------------------------------------------------------------------
0060149E                          1696  * Output a word as 4 ASCII hexadecimal digits
0060149E                          1697  * D0 holds the word in bits 0..15
0060149E                          1698  * NOTE: the writeByte function must be directly after this function
0060149E                          1699  *------------------------------------------------------------------------------
0060149E                          1700  writeWord:
0060149E  3F00                    1701      move.w  d0,-(sp)    ; save D0 first
006014A0  E058                    1702      ror.w   #8,d0       ; get upper byte (0 => shift 8 times)
006014A2  6102                    1703      bsr.s   writeByte
006014A4  301F                    1704      move.w  (sp)+,d0    ; restore D0
006014A6                          1705  
006014A6                          1706  *------------------------------------------------------------------------------
006014A6                          1707  * Output a byte as 2 ASCII hexadecimal digits
006014A6                          1708  * D0 holds the byte in bits 0..7
006014A6                          1709  * NOTE: the writeNibble function must be directly after this function
006014A6                          1710  *------------------------------------------------------------------------------
006014A6                          1711  writeByte:
006014A6  1F00                    1712      move.b  d0,-(sp)    ; save D0 first
006014A8  E818                    1713      ror.b   #4,d0       ; get upper nibble
006014AA  6102                    1714      bsr.s   writeNibble
006014AC  101F                    1715      move.b  (sp)+,d0    ; restore D0
006014AE                          1716      
006014AE                          1717  *------------------------------------------------------------------------------
006014AE                          1718  * Output 4 bits as an ASCII hexadecimal digit
006014AE                          1719  * D0 holds the nibble in bits 0..3
006014AE                          1720  *------------------------------------------------------------------------------
006014AE                          1721  writeNibble:
006014AE  1F00                    1722      move.b  d0,-(sp)    ; save D0 first
006014B0  0200 000F               1723      andi.b  #$0F,d0     ; make sure we only have the lower 4 bits
006014B4  0C00 000A               1724      cmpi.b  #10,d0      ; compare D0 to 10
006014B8  6502                    1725      bcs.b   .wn1        ; less than 10 so don't add 7
006014BA  5E00                    1726      addi.b  #07,d0      ; add 7
006014BC                          1727  .wn1:
006014BC  0600 0030               1728      addi.b  #'0',d0     ; add ASCII code for char zero
006014C0  6100 0050               1729      bsr     putCh       ; write the ASCII digit out
006014C4  101F                    1730      move.b  (sp)+,d0    ; restore D0
006014C6  4E75                    1731      rts
006014C8                          1732  
006014C8                          1733  *------------------------------------------------------------------------------
006014C8                          1734  * Prints a newline (CR, LF)
006014C8                          1735  * NOTE: the putString function must follow this function
006014C8                          1736  *------------------------------------------------------------------------------
006014C8                          1737  putCRLF:
006014C8  41FA 02D9               1738      lea     strNewline(PC), a0
006014CC                          1739  
006014CC                          1740  *------------------------------------------------------------------------------
006014CC                          1741  * Write a null terminated string to SCC1, blocking if tx buffer is not ready
006014CC                          1742  * A0 holds the address of the first character of the null terminated string
006014CC                          1743  *------------------------------------------------------------------------------
006014CC                          1744  putString:
006014CC  48E7 8040               1745      movem.l d0/a1,-(sp)             * save d0 & a1
006014D0                          1746  
006014D0                          1747  .ps_1:
006014D0  0839 0007 00FFF440      1748      btst.b  #7,M302_SCC1PB+M302_TXBD0           * test the R bit in TXBD0
006014D8  66F6                    1749      bne.s   .ps_1                   * test again if R=1
006014DA                          1750  
006014DA                          1751      * SCC1 TX buffer #0 is available for use
006014DA  227C 00FFF000           1752      movea.l #SCC1TXB0,a1            * A1 points to SCC1 Tx buffer
006014E0  4280                    1753      clr.l   d0                      * clear our char counter
006014E2                          1754  
006014E2                          1755  .ps_2:
006014E2  12D8                    1756      move.b  (a0)+,(a1)+             * copy the char to SCC1 Tx buffer
006014E4  6718                    1757      beq.s   .ps_ex                  * done if it's a NULL
006014E6  5240                    1758      addq.w  #1,d0                   * increment tx buffer char count
006014E8  0C40 007F               1759      cmpi.w  #SER1_BUFSIZE-1,d0      * have we filled the tx buffer?
006014EC  66F4                    1760      bne.s   .ps_2
006014EE                          1761      
006014EE                          1762      * SCC1 TX buffer is full so send it
006014EE  33C0 00FFF442           1763      move.w  d0,M302_SCC1PB+M302_TXBD0+2     * write number of chars to send
006014F4  0079 8000 00FFF440      1764      ori.w   #$8000,M302_SCC1PB+M302_TXBD0       * signal tx buffer ready
006014FC  60D2                    1765      bra.s   .ps_1                   * go back and wait for buffer to empty
006014FE                          1766  
006014FE                          1767  .ps_ex:
006014FE  33C0 00FFF442           1768      move.w  d0,M302_SCC1PB+M302_TXBD0+2     * write number of chars to send
00601504  0079 8000 00FFF440      1769      ori.w   #$8000,M302_SCC1PB+M302_TXBD0       * signal tx buffer ready
0060150C                          1770  
0060150C  4CDF 0201               1771      movem.l (sp)+,d0/a1             * restore d0 & a1
00601510  4E75                    1772      rts
00601512                          1773  
00601512                          1774  *------------------------------------------------------------------------------
00601512                          1775  * Write a character to SCC1, blocking if UART is not ready
00601512                          1776  * D0 = char to send
00601512                          1777  *------------------------------------------------------------------------------
00601512                          1778  putCh:
00601512  0839 0007 00FFF440      1779      btst.b  #7,M302_SCC1PB+M302_TXBD0           * test the R bit in TXBD0
0060151A  66F6                    1780      bne.s   putCh                   * test again if R=1
0060151C                          1781  
0060151C                          1782      * SCC1 TX buffer is available for use
0060151C  13C0 00FFF000           1783      move.b  d0,SCC1TXB0             * write the char to the tx buffer
00601522  33FC 0001 00FFF442      1784      move.w  #1,M302_SCC1PB+M302_TXBD0+2     * set 1 char to send
0060152A  0079 8000 00FFF440      1785      ori.w   #$8000,M302_SCC1PB+M302_TXBD0       * signal tx buffer ready
00601532  4E75                    1786      rts
00601534                          1787  
00601534                          1788  *------------------------------------------------------------------------------
00601534                          1789  * Read a character from SCC1 - blocking call so will wait for character
00601534                          1790  * Check both Rx buffers for a character. If it's an S, then don't free the
00601534                          1791  * buffer as the S-record routine will do that.
00601534                          1792  * D0 = recevied char
00601534                          1793  * If it's an S-record then A0=addr of buffer & A2=addr of flags
00601534                          1794  *------------------------------------------------------------------------------
00601534                          1795  getCh:
00601534                          1796      * check Rx buffer #0
00601534  3039 00FFF400           1797      move.w  M302_SCC1PB+M302_RXBD0,d0           * read RxBD #0 status flags
0060153A  0240 8000               1798      andi.w  #$8000,d0               * mask all but the empty flag
0060153E  6624                    1799      bne.s   .getCh1                 * check RxBD #1
00601540                          1800      
00601540  1039 00FFF080           1801      move.b  SCC1RXB0,d0             * get the received char
00601546  0C00 0053               1802      cmpi.b  #'S',d0                 * is it the start of an S-record?
0060154A  660E                    1803      bne.s   .ex1
0060154C  207C 00FFF080           1804      move.l  #SCC1RXB0,a0            * A0 = addr of buffer
00601552  247C 00FFF400           1805      move.l  #M302_SCC1PB+M302_RXBD0,a2        * A2 = addr of buffer flags
00601558  4E75                    1806      rts                             * exit without freeing buffer
0060155A                          1807  .ex1:
0060155A  0079 8000 00FFF400      1808      ori.w   #$8000,M302_SCC1PB+M302_RXBD0       * signal buffer is free
00601562  4E75                    1809      rts
00601564                          1810  
00601564                          1811  .getCh1:
00601564                          1812      * check Rx buffer #1
00601564  3039 00FFF408           1813      move.w  M302_SCC1PB+M302_RXBD1,d0           * read RxBD #1 status flags
0060156A  0240 8000               1814      andi.w  #$8000,d0               * mask all but the empty flag
0060156E  66C4                    1815      bne.s   getCh                   * check RxBD #0 again
00601570                          1816      
00601570  1039 00FFF100           1817      move.b  SCC1RXB1,d0             * read the receved char
00601576  0C00 0053               1818      cmpi.b  #'S',d0                 * is it the start of an S-record?
