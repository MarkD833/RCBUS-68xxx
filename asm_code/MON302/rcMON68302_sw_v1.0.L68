00600EC2                           918      ORG     (*+1)&-2                    * make sure we start on a word aligned address
00600EC2                           919  monStart:
00600EC2  41FA 06FA                920      lea     strBanner1(PC), a0  * Show the monitor details
00600EC6  6100 0604                921      bsr.w   putString
00600ECA                           922  
00600ECA  41FA 0755                923      lea     strCommands(PC), a0 * And the command help message
00600ECE  6100 05FC                924      bsr.w   putString
00600ED2                           925  
00600ED2                           926  monLoop:
00600ED2  41FA 08BA                927      lea     strPrompt(PC), a0   * Prompt
00600ED6  6100 05F4                928      bsr.w   putString
00600EDA                           929  
00600EDA                           930  monLoop_NP:
00600EDA  6100 0658                931      bsr.w   getCh           * get a character into D0
00600EDE  6100 02D2                932      bsr.w   chToUpper       * convert character to upper case
00600EE2                           933      
00600EE2  0C00 000A                934      cmpi.b  #ASCII_LF,d0    * ignore Line-Feed
00600EE6  67EA                     935      beq.s   monLoop
00600EE8                           936  
00600EE8  B03C 0044                937      cmp.b   #'D', d0        * Dump memory command
00600EEC  6700 004E                938      beq.w   cmdDispMemory
00600EF0                           939  
00600EF0  B03C 0049                940      cmp.b   #'I', d0        * Read from I/O space address
00600EF4  6700 0090                941      beq.w   cmdIORead
00600EF8                           942  
00600EF8  B03C 004D                943      cmp.b   #'M', d0        * Modify memory command
00600EFC  6700 00CA                944      beq.w   cmdModifyMemory
00600F00                           945  
00600F00  B03C 004F                946      cmp.b   #'O', d0        * Write to I/O space address
00600F04  6700 0120                947      beq.w   cmdIOWrite
00600F08                           948  
00600F08  B03C 0053                949      cmp.b   #'S', d0        * S record download
00600F0C  6700 0162                950      beq.w   cmdDownload
00600F10                           951  
00600F10  B03C 0047                952      cmp.b   #'G', d0        * Go command
00600F14  6700 0048                953      beq.w   cmdRun
00600F18                           954  
00600F18  B03C 003F                955      cmp.b   #'?', d0        * Help command
00600F1C  6700 0222                956      beq.w   cmdHelp
00600F20                           957  
00600F20  B03C 0020                958      cmp.b   #' ', d0        * Ignore spaces
00600F24  6FB4                     959      ble.s   monLoop_NP      * go back without printing prompt    
00600F26                           960  
00600F26  1200                     961      move.b  d0,d1           * save the unknown char
00600F28  41FA 0867                962      lea     strUnkCmd(PC), a0   * unknown command
00600F2C  6100 059E                963      bsr.w   putString
00600F30  1001                     964      move.b  d1,d0           * get unnknown char back
00600F32  6100 0572                965      bsr.w   writeByte       * print it
00600F36                           966      
00600F36                           967  monLoop_CRLF:
00600F36  6100 0590                968      bsr.w   putCRLF
00600F3A  6096                     969      bra.s   monLoop
00600F3C                           970  
00600F3C                           971  *------------------------------------------------------------------------------
00600F3C                           972  * (D)ump memory
00600F3C                           973  * Display 256 bytes of memory as ASCII-HEX characters
00600F3C                           974  *------------------------------------------------------------------------------
00600F3C                           975  cmdDispMemory:
00600F3C  6100 05D4                976      bsr.w   putCh           * echo back the command character in D0
00600F40  103C 0020                977      move.b  #' ',d0
00600F44  6100 05CC                978      bsr.w   putCh
00600F48                           979      
00600F48  4282                     980      clr.l   d2              * pre-set D2 to 0
00600F4A  7208                     981      move.l  #8,d1           * read up to 8 digits
00600F4C  6100 02C2                982      bsr.w   hexToIntEcho    * from the serial port into D0
00600F50  6500 FF80                983      bcs.w   monLoop         * back to prompt if there's an error
00600F54                           984      
00600F54  2040                     985      move.l  d0,a0           * A0 holds the start address
00600F56  6100 01F4                986      bsr.w   dumpRAM
00600F5A                           987  
00600F5A  6000 FF76                988      bra.w   monLoop
00600F5E                           989  
00600F5E                           990  *------------------------------------------------------------------------------
00600F5E                           991  * (G)o - execute code in memory starting at the specified address
00600F5E                           992  *------------------------------------------------------------------------------
00600F5E                           993  cmdRun:
00600F5E  6100 05B2                994      bsr.w   putCh           * echo back the command character in D0
00600F62  103C 0020                995      move.b  #' ',d0
00600F66  6100 05AA                996      bsr.w   putCh
00600F6A                           997  
00600F6A  4282                     998      clr.l   d2              * pre-set D2 to 0
00600F6C  7208                     999      move.l  #8,d1           * read up to 8 digits
00600F6E  6100 02A0               1000      bsr.w   hexToIntEcho    * from the serial port
00600F72  6500 FF5E               1001      bcs.w   monLoop         * back to prompt if there's an error
00600F76                          1002  
00600F76  2040                    1003      move.l  d0, a0          * copy start address into A0
00600F78  4E90                    1004      jsr     (a0)            * jump to user code
00600F7A                          1005      
00600F7A  41FA 0844               1006      lea     strUserReturn(PC),a0
00600F7E  6100 054C               1007      bsr.w   putString
00600F82                          1008      
00600F82  6000 FF4E               1009      bra.w   monLoop
00600F86                          1010  
00600F86                          1011  *------------------------------------------------------------------------------
00600F86                          1012  * (I)nput a byte from I/O space address
00600F86                          1013  *------------------------------------------------------------------------------
00600F86                          1014  cmdIORead:
00600F86  6100 058A               1015      bsr.w   putCh           * echo back the command character in D0
00600F8A  103C 0020               1016      move.b  #' ',d0
00600F8E  6100 0582               1017      bsr.w   putCh
00600F92                          1018  
00600F92  4282                    1019      clr.l   d2              * pre-set D2 to 0
00600F94  7202                    1020      move.l  #2,d1           * read up to 2 digit address
00600F96  6100 0278               1021      bsr.w   hexToIntEcho    * from the serial port
00600F9A  6500 FF36               1022      bcs.w   monLoop         * back to prompt if there's an error
00600F9E  1600                    1023      move.b  d0,d3           * save the typed in 8-bit address
00600FA0  103C 003D               1024      move.b  #'=',d0
00600FA4  6100 056C               1025      bsr.w   putCh           * send an EQUALS
00600FA8                          1026  
00600FA8                          1027      ; D3 = 8-bit address
00600FA8  207C 00FD0000           1028      movea.l #RCIO_BASE,a0
00600FAE  0283 000000FF           1029      andi.l  #$FF,d3         * clear all the unused bits
00600FB4  E383                    1030      asl.l   #1,d3           * make it a word offset
00600FB6  5283                    1031      addi.l  #1,d3           * make it an odd address to read from D0..D7
00600FB8  1030 3000               1032      move.b  (0,a0,d3),d0    * and read the new value in
00600FBC  6100 04E8               1033      bsr.w   writeByte       * display the value
00600FC0  6100 0506               1034      bsr.w   putCRLF
00600FC4  6000 FF0C               1035      bra.w   monLoop
00600FC8                          1036  
00600FC8                          1037  *------------------------------------------------------------------------------
00600FC8                          1038  * (M)odify memory
00600FC8                          1039  * Change memory contents 1 byte at a time
00600FC8                          1040  *------------------------------------------------------------------------------
00600FC8                          1041  cmdModifyMemory:
00600FC8  6100 0548               1042      bsr.w   putCh           * echo back the command character in D0
00600FCC  103C 0020               1043      move.b  #' ',d0
00600FD0  6100 0540               1044      bsr.w   putCh
00600FD4                          1045  
00600FD4  4282                    1046      clr.l   d2              * pre-set D2 to 0
00600FD6  7208                    1047      move.l  #8,d1           * read up to 8 digits
00600FD8  6100 0236               1048      bsr.w   hexToIntEcho    * from the serial port
00600FDC  6500 FEF4               1049      bcs.w   monLoop         * back to prompt if there's an error
00600FE0  1200                    1050      move.b  d0,d1           * save the typed in address
00600FE2  6100 04E4               1051      bsr.w   putCRLF
00600FE6  1001                    1052      move.b  d1,d0           * restore the typed in address
00600FE8                          1053      
00600FE8  2040                    1054      move.l  d0,a0           * copy address into A0
00600FEA                          1055  .cMM_1:
00600FEA  6100 049C               1056      bsr.w   writeAddr32     * display the memory location address
00600FEE  103C 0020               1057      move.b  #' ',d0
00600FF2  6100 051E               1058      bsr.w   putCh
00600FF6  1010                    1059      move.b  (a0),d0         * get the current memory contents
00600FF8  1400                    1060      move.b  d0,d2           * pre-set D2 to the existing memory value
00600FFA  6100 04AA               1061      bsr.w   writeByte       * display the byte
00600FFE  103C 0020               1062      move.b  #' ',d0
00601002  6100 050E               1063      bsr.w   putCh
00601006  7202                    1064      move.l  #2,d1           * read up to 2 digits
00601008  6100 0206               1065      bsr.w   hexToIntEcho    * from the serial port
0060100C  6500 0010               1066      bcs.w   .cMM_2          * back to prompt if there's an error
00601010                          1067  
00601010  10C0                    1068      move.b  d0,(a0)+        * write out the new byte and move on
00601012  2F08                    1069      move.l  a0,-(SP)        * save our address
00601014  6100 04B2               1070      bsr.w   putCRLF
00601018  205F                    1071      move.l  (SP)+,a0        * restore our address
0060101A  2008                    1072      move.l  a0,d0           * copy address back into D0 for printing
0060101C  60CC                    1073      bra.s   .cMM_1
0060101E                          1074  
0060101E                          1075  .cMM_2:
0060101E  6100 04A8               1076      bsr.w   putCRLF
00601022  6000 FEAE               1077      bra.w   monLoop
