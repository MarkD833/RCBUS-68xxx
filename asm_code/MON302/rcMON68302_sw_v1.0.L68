00000000                           300  *******************************************************************************
00000000                           301  * 68302 Exception Vector Table - to be copied into RAM at address 0x000000
00000000                           302  * NOTE: The reset value in Base Register 0 (BR0) configures the ROM chip select
00000000                           303  * (/CS0) so that ROM appears at address 0x000000. The initial PC value in the
00000000                           304  * table has to point to the address of the startup code when the ROM is at
00000000                           305  * address 0x000000. Subtract ROM_BASE from the address of the label START. 
00000000                           306  *******************************************************************************
00000000                           307     
00600000                           308      ORG     ROM_BASE
00600000                           309  
00600000= 000FF800                 310      DC.L    STACK_START    *00 Supervisor stack pointer
00600004= 00000400                 311      DC.L    START-ROM_BASE *01 Initial PC (adjusted for the ROM being at 0x000000)
00600008                           312  
