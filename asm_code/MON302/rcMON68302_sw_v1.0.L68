00000000                           273  *------------------------------------------------------------------------------
00000000                           274  * Helpers for the 68302 chip select base and option registers
00000000                           275  * CS0 selects the ROM
00000000                           276  * CS1 selects the RAM
00000000                           277  * CS2 selects RCBus MEM space (A16=0) or IO space (A16=1)
00000000                           278  *
00000000                           279  * NOTES:
00000000                           280  * + These settings are for when the ROM/RAM switch has happened.
00000000                           281  * + OR in 0x0001 to the BR values to set the ENABLE bit for the chip select logic!
00000000                           282  *------------------------------------------------------------------------------
00000000  =00000C01                283  CS0_BR      EQU (ROM_BASE>>11)|$0001
00000000  =00001E00                284  CS0_OR      EQU (~(ROM_SIZE-1)>>11)&$1FFC
00000000  =00000001                285  CS1_BR      EQU (RAM_BASE>>11)|$0001
00000000  =00001E00                286  CS1_OR      EQU (~((RAM_SIZE-1)>>11))&$1FFC
00000000  =00001F81                287  CS2_BR      EQU (RCBUS_BASE>>11)|$0001
00000000  =00001FC0                288  CS2_OR      EQU (~((RCBUS_SIZE-1)>>11))&$1FFC
