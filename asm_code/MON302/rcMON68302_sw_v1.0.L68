0060130E                          1472  
0060130E                          1473  easyTask2: 
0060130E                          1474  easyTask3:
0060130E                          1475  easyTask4:
0060130E                          1476  easyTask8: 
0060130E                          1477  easyTask9: 
0060130E                          1478  easyTask10:
0060130E                          1479  easyTask11:
0060130E                          1480  easyTask12:
0060130E                          1481  easyTask15:
0060130E                          1482  easyTask16:
0060130E                          1483  easyTask17:
0060130E                          1484  easyTask18:
0060130E                          1485  easyTask19:
0060130E                          1486  easyTask20:
0060130E                          1487  easyTask21:
0060130E                          1488  easyTask22:
0060130E                          1489  easyTask23:
0060130E                          1490  easyTask24:
0060130E                          1491  easyTask25:
0060130E                          1492  easyTaskUnsupported:
0060130E  C141                    1493      exg     d0,d1           ; put the task number into D1
00601310  41FA 04CA               1494      lea     strEasyTask1(PC), a0
00601314  6100 01B6               1495      bsr.w   putString
00601318  C141                    1496      exg     d0,d1           ; put the task number back into D0
0060131A  80FC 000A               1497      divu    #10,d0          ; divide task number by 10
0060131E  6100 018E               1498      bsr.w   writeNibble     ; output the 10's digit
00601322  4840                    1499      swap    d0
00601324  6100 0188               1500      bsr.w   writeNibble     ; output the 1's digit
00601328  41FA 04D3               1501      lea     strEasyTask2(PC), a0
0060132C  6100 019E               1502      bsr.w   putString
00601330                          1503  .infloop:
00601330  60FE                    1504      bra.s   .infloop
