00007178                           467  *******************************************************************************
00007178                           468  *
00007178                           469  *  ######     #    #     #       #     # #######  #####  ####### ####### ######   #####  
00007178                           470  *  #     #   # #   ##   ##       #     # #       #     #    #    #     # #     # #     # 
00007178                           471  *  #     #  #   #  # # # #       #     # #       #          #    #     # #     # #       
00007178                           472  *  ######  #     # #  #  #       #     # #####   #          #    #     # ######   #####  
00007178                           473  *  #   #   ####### #     #        #   #  #       #          #    #     # #   #         # 
00007178                           474  *  #    #  #     # #     #         # #   #       #     #    #    #     # #    #  #     # 
00007178                           475  *  #     # #     # #     #          #    #######  #####     #    ####### #     #  #####  
00007178                           476  *                                                                                       
00007178                           477  *******************************************************************************
00007178                           478  * 68000 RAM Exception Vector Table
00007178                           479  *
00007178                           480  * This is the initial exception vector table that gets copied into RAM.
00007178                           481  * It initially redirects back to the basic exception handlers in ROM until the
00007178                           482  * user program inserts their own exception handler address.
00007178                           483  *******************************************************************************
00007178                           484  
00007178                           485      ORG     (*+1)&-2       * make sure the table is word aligned
00007178                           486  
00007178                           487  ramIVT:
00007178= 001FF800                 488      DC.L    STACK_START    *00 Supervisor stack pointer
0000717C= 00007EE8                 489      DC.L    START          *01 Initial PC    
00007180                           490  
00007180= 00007578                 491      DC.L    handleBusErr   *02 Bus Error
00007184= 00007590                 492      DC.L    handleAddrErr  *03 Address Error
00007188= 000075A8                 493      DC.L    handleIllInst  *04 Illegal Instruction
0000718C= 000075B0                 494      DC.L    handleZeroDiv  *05 Zero Divide
00007190= 000075B8                 495      DC.L    handleChkInst  *06 CHK Instruction
00007194= 000075C0                 496      DC.L    handleTrapV    *07 TRAPV Instruction
00007198= 000075C8                 497      DC.L    handlePriv     *08 Privilege Violation
0000719C= 000075D0                 498      DC.L    handleTrace    *09 Trace
000071A0= 000075D8                 499      DC.L    handleLineA    *0A Line 1010 Emulator
000071A4= 000075E0                 500      DC.L    handleLineF    *0B Line 1111 Emulator
000071A8= 000075E8                 501      DC.L    handleRes1     *0C (Unassigned, Reserved)
000071AC= 000075E8                 502      DC.L    handleRes2     *0D (Unassigned, Reserved)
000071B0= 000075E8                 503      DC.L    handleRes3     *0E (Unassigned, Reserved)
000071B4= 000075F0                 504      DC.L    handleUnInit   *0F Uninitialized Interrupt Vector
000071B8= 000075E8                 505      DC.L    handleRes4     *10 (Unassigned, Reserved)
000071BC= 000075E8                 506      DC.L    handleRes5     *11 (Unassigned, Reserved)
000071C0= 000075E8                 507      DC.L    handleRes6     *12 (Unassigned, Reserved)
000071C4= 000075E8                 508      DC.L    handleRes7     *13 (Unassigned, Reserved)
000071C8= 000075E8                 509      DC.L    handleRes8     *14 (Unassigned, Reserved)
000071CC= 000075E8                 510      DC.L    handleRes9     *15 (Unassigned, Reserved)
000071D0= 000075E8                 511      DC.L    handleRes10    *16 (Unassigned, Reserved)
000071D4= 000075E8                 512      DC.L    handleRes11    *17 (Unassigned, Reserved)
000071D8= 000075F8                 513      DC.L    handleSpur     *18 Spurious Interrupt
000071DC= 00007600                 514      DC.L    handleAV1      *19 Level 1 Interrupt Autovector
000071E0= 00008374                 515      DC.L    serISR         *1A Level 2 Interrupt Autovector
000071E4= 00007610                 516      DC.L    handleAV3      *1B Level 3 Interrupt Autovector
000071E8= 00007618                 517      DC.L    handleAV4      *1C Level 4 Interrupt Autovector
000071EC= 00007620                 518      DC.L    handleAV5      *1D Level 5 Interrupt Autovector
000071F0= 00007628                 519      DC.L    handleAV6      *1E Level 6 Interrupt Autovector
000071F4= 00007630                 520      DC.L    handleAV7      *1F Level 7 Interrupt Autovector
000071F8= 00007638                 521      DC.L    handleTrap0    *20 TRAP #0  Instruction Vector
000071FC= 00007640                 522      DC.L    handleTrap1    *21 TRAP #1  Instruction Vector
00007200= 00007648                 523      DC.L    handleTrap2    *22 TRAP #2  Instruction Vector
00007204= 00007650                 524      DC.L    handleTrap3    *23 TRAP #3  Instruction Vector
00007208= 00007658                 525      DC.L    handleTrap4    *24 TRAP #4  Instruction Vector
0000720C= 00007660                 526      DC.L    handleTrap5    *25 TRAP #5  Instruction Vector
00007210= 00007668                 527      DC.L    handleTrap6    *26 TRAP #6  Instruction Vector
00007214= 00007670                 528      DC.L    handleTrap7    *27 TRAP #7  Instruction Vector
00007218= 00007678                 529      DC.L    handleTrap8    *28 TRAP #8  Instruction Vector
0000721C= 00007680                 530      DC.L    handleTrap9    *29 TRAP #9  Instruction Vector
00007220= 00007688                 531      DC.L    handleTrap10   *2A TRAP #10 Instruction Vector
00007224= 00007690                 532      DC.L    handleTrap11   *2B TRAP #11 Instruction Vector
00007228= 00007698                 533      DC.L    handleTrap12   *2C TRAP #12 Instruction Vector
0000722C= 000076A0                 534      DC.L    handleTrap13   *2D TRAP #13 Instruction Vector
00007230= 000076A8                 535      DC.L    handleTrap14   *2E TRAP #14 Instruction Vector
00007234= 0000851E                 536      DC.L    easy68kTrap15  *2F TRAP #15 Instruction Vector
00007238                           537  
00007238= 000076B8 000076B8 ...    538      DCB.L   208,handleUnused
00007578                           539  
00007578                           540  *******************************************************************************
00007578                           541  * Below are the actual exception handlers that the RAM based vector table
00007578                           542  * initially points to. The user can overwrite the RAM vector table addresses
00007578                           543  * with the address of their own exception handler. These basic handlers simply
00007578                           544  * write a message to the serial port and enter an endless loop.
00007578                           545  *******************************************************************************
00007578                           546  
00007578                           547  *------------------------------------------------------------------------------
00007578                           548  * BUS ERROR handler
00007578                           549  * Print a message showing the PC and address being accessed
00007578                           550  *------------------------------------------------------------------------------
00007578                           551  handleBusErr:
00007578  41FA 0372                552      lea     bemsg1(PC), a0      * A0 = first message address
0000757C  6100 1004                553      bsr.w   putString           * display it
00007580  202F 000A                554      move.l  10(a7),d0           * get the program counter 
00007584  6100 0FB8                555      bsr.w   writeAddr32         * display it
00007588                           556      
00007588  41FA 03A1                557      lea     bemsg2(PC), a0      * A0 = second message address
0000758C  6000 0132                558      bra.w   handleCleanUp
00007590                           559      
00007590                           560  *------------------------------------------------------------------------------
00007590                           561  * ADDRESS ERROR handler
00007590                           562  * Print a message showing the PC and address being accessed
00007590                           563  *------------------------------------------------------------------------------
00007590                           564  handleAddrErr:
00007590  41FA 0140                565      lea     aemsg1(PC), a0      * A0 = first message address
00007594  6100 0FEC                566      bsr.w   putString           * display it
00007598  202F 000A                567      move.l  10(a7),d0           * get the program counter 
0000759C  6100 0FA0                568      bsr.w   writeAddr32         * display it
000075A0                           569      
000075A0  41FA 0174                570      lea     aemsg2(PC), a0      * A0 = second message address
000075A4  6000 011A                571      bra.w   handleCleanUp
000075A8                           572      
000075A8                           573  *------------------------------------------------------------------------------
000075A8                           574  * ILLEGAL INSTRUCTION handler
000075A8                           575  *------------------------------------------------------------------------------
000075A8                           576  handleIllInst:
000075A8  41FA 03E0                577      lea     iimsg(PC), a0       * A0 = address of message to display
000075AC  6000 0112                578      bra.w   handleCleanUp
000075B0                           579      
000075B0                           580  *------------------------------------------------------------------------------
000075B0                           581  * DIVISION BY ZERO handler
000075B0                           582  *------------------------------------------------------------------------------
000075B0                           583  handleZeroDiv:
000075B0  41FA 0901                584      lea     zdmsg(PC), a0       * A0 = address of message to display
000075B4  6000 010A                585      bra.w   handleCleanUp
000075B8                           586      
