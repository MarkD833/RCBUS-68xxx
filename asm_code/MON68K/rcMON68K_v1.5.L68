00000000                           155  *******************************************************************************
00000000                           156  * The serial port originally ran at 38400 baud for the MC68681 SIO chip.
00000000                           157  * Alternative compatibe chips were made by Philips (SCC68681,SCN68681 & SCC68692)
00000000                           158  * that supported higher baud rates using a special test mode.
00000000                           159  * Set HI_SPEED to 1 to enable 115200 baud or 0 for standard 38400 baud.  
00000000                           160  *******************************************************************************
00000000  =00000000                161  HI_SPEED    equ 0
00000000                           162  
00000000                           163  *******************************************************************************
00000000                           164  * ramVecJump : Macro to "jump" to exception handler in the RAM vector table
00000000                           165  * Parameter \1 is the vector number 
00000000                           166  * Put the handler address held in RAM onto the stack and RET to it
00000000                           167  *******************************************************************************
00000000                           168  ramVecJump  MACRO
00000000                           169      move.l  VEC_BASE+(\1<<2),-(SP)
00000000                           170      rts
00000000                           171      ENDM
00000000                           172  
00000000                           173  *------------------------------------------------------------------------------
00000000                           174  * ASCII control characters
00000000                           175  *------------------------------------------------------------------------------
00000000  =0000000A                176  LF    equ $0A
00000000  =0000000D                177  CR    equ $0D
00000000                           178  
00000000                           179  *------------------------------------------------------------------------------
00000000                           180  * Serial port receive buffer size - must be multiples of 2!
00000000                           181  * UPPER sets max chars in buffer before asking host PC to stop sending.
00000000                           182  * LOWER sets min chars in buffer before asking host PC to start sending again.
00000000                           183  *------------------------------------------------------------------------------
00000000  =00000100                184  SERIAL_BUFFER_SIZE  equ 256
00000000  =000000FF                185  SERIAL_BUFFER_MASK  equ SERIAL_BUFFER_SIZE-1
00000000  =000000C8                186  SERIAL_BUFFER_UPPER equ 200
00000000  =00000019                187  SERIAL_BUFFER_LOWER equ 25
