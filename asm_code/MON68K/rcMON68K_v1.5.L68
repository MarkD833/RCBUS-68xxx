00007EE7                           884  *******************************************************************************
00007EE7                           885  *
00007EE7                           886  *   #####  ####### #       ######         #####  #######    #    ######  ####### 
00007EE7                           887  *  #     # #     # #       #     #       #     #    #      # #   #     #    #    
00007EE7                           888  *  #       #     # #       #     #       #          #     #   #  #     #    #    
00007EE7                           889  *  #       #     # #       #     #        #####     #    #     # ######     #    
00007EE7                           890  *  #       #     # #       #     #             #    #    ####### #   #      #    
00007EE7                           891  *  #     # #     # #       #     #       #     #    #    #     # #    #     #    
00007EE7                           892  *   #####  ####### ####### ######         #####     #    #     # #     #    #    
00007EE7                           893  *                                                                               
00007EE7                           894  *******************************************************************************
00007EE7                           895  * Monitor execution starts here after power-on or a reset.
00007EE7                           896  *******************************************************************************
00007EE7                           897  
00007EE8                           898      ORG     (*+1)&-2    * make sure we start on a word aligned address
00007EE8                           899  START:
00007EE8  4FF9 001FF800            900      lea     STACK_START, sp     * Set the stack pointer just in case
00007EEE                           901  
00007EEE                           902      * copy the RAM exception vector table into RAM
00007EEE  207C 00007178            903      move.l  #ramIVT,a0          * start of RAM exception table in ROM
00007EF4  227C 00100000            904      move.l  #VEC_BASE,a1        * location in RAM to copy table to
00007EFA  203C 000000FF            905      move.l  #255,d0             * 256 entries to copy
00007F00                           906  .copy:
00007F00  22D8                     907      move.l  (a0)+,(a1)+         * copy the byte from ROM to RAM
00007F02  51C8 FFFC                908      dbra    d0,.copy
00007F06                           909  
00007F06  6100 0408                910      bsr.w   serInit             * initialise serial port
00007F0A  46FC 2000                911      move.w  #$2000,sr           * enable interrupts
00007F0E                           912  
00007F0E                           913  *------------------------------------------------------------------------------
00007F0E                           914  * Warm Restart entry point
00007F0E                           915  *------------------------------------------------------------------------------
00007F0E                           916  monStart:
00007F0E  41FA 067E                917      lea     strBanner1(PC), a0  * Show the monitor details
00007F12  6100 066E                918      bsr.w   putString
00007F16                           919  
00007F16  41FA 06D4                920      lea     strCommands(PC), a0 * And the command help message
00007F1A  6100 0666                921      bsr.w   putString
00007F1E                           922  
00007F1E                           923  monLoop:
00007F1E  41FA 0873                924      lea     strPrompt(PC), a0   * Prompt
00007F22  6100 065E                925      bsr.w   putString
00007F26                           926  
00007F26                           927  monLoop_NP:
00007F26  6100 04BC                928      bsr.w   getc                * get a character into D0
00007F2A  6100 0348                929      bsr.w   chToUpper           * convert character to upper case
00007F2E                           930      
00007F2E  0C00 000A                931      cmpi.b  #LF,d0              * ignore Line-Feed
00007F32  67EA                     932      beq.s   monLoop
00007F34                           933      
00007F34  B03C 0042                934      cmp.b   #'B', d0            * Boot EhBASIC v3.54
00007F38  6700 005E                935      beq.w   cmdBootEHBASIC
00007F3C                           936  
00007F3C  B03C 0043                937      cmp.b   #'C', d0            * Boot CP/M-68K
00007F40  6700 007E                938      beq.w   cmdBootCPM
00007F44                           939  
00007F44  B03C 0044                940      cmp.b   #'D', d0            * Dump memory command
00007F48  6700 00B0                941      beq.w   cmdDispMemory
00007F4C                           942  
00007F4C  B03C 0049                943      cmp.b   #'I', d0            * Read from I/O space address
00007F50  6700 00F2                944      beq.w   cmdIORead
00007F54                           945  
00007F54  B03C 004D                946      cmp.b   #'M', d0            * Modify memory command
00007F58  6700 012C                947      beq.w   cmdModifyMemory
00007F5C                           948  
00007F5C  B03C 004F                949      cmp.b   #'O', d0            * Write to I/O space address
00007F60  6700 0182                950      beq.w   cmdIOWrite
00007F64                           951  
00007F64  B03C 0053                952      cmp.b   #'S', d0            * S record download
00007F68  6700 01C4                953      beq.w   cmdDownload
00007F6C                           954  
00007F6C  B03C 0047                955      cmp.b   #'G', d0            * Go command
00007F70  6700 00AA                956      beq.w   cmdRun
00007F74                           957  
00007F74  B03C 003F                958      cmp.b   #'?', d0            * Help command
00007F78  6700 0288                959      beq.w   cmdHelp
00007F7C                           960  
00007F7C  B03C 0020                961      cmp.b   #' ', d0            * Ignore spaces
00007F80  6FA4                     962      ble.s   monLoop_NP          * go back without printing prompt    
00007F82                           963  
00007F82  1200                     964      move.b  d0,d1               * save the unknown char
00007F84  41FA 0810                965      lea     strUnkCmd(PC), a0   * unknown command
00007F88  6100 05F8                966      bsr.w   putString
00007F8C  1001                     967      move.b  d1,d0               * get unnknown char back
00007F8E  6100 05CC                968      bsr.w   writeByte           * print it
00007F92                           969      
00007F92                           970  monLoop_CRLF:
00007F92  6100 05EA                971      bsr.w   putCRLF
00007F96  6086                     972      bra.s   monLoop
00007F98                           973      
00007F98                           974  *------------------------------------------------------------------------------
00007F98                           975  * (B) Boot EhBASIC v3.54
00007F98                           976  *------------------------------------------------------------------------------
00007F98                           977  cmdBootEHBASIC:
00007F98                           978      * Perform a simple check to see if EhBASIC has been programmed into the
00007F98                           979      * EEPROM by reading the first address of EhBASIC in the EEPROM. If it
00007F98                           980      * contains 0xFFFF, then EhBASIC hasn't been programmed in!
00007F98  0C79 FFFF 00009000       981      cmpi.w  #$FFFF,EHBASIC_BASE
00007FA0  660C                     982      bne.s   .bootEHBASIC
00007FA2  41FA 0924                983      lea     strBASICErr1(PC), a0
00007FA6  6100 05DA                984      bsr.w   putString
00007FAA  6000 FF72                985      bra.w   monLoop
00007FAE                           986  
00007FAE                           987  .bootEHBASIC:
00007FAE  207C 00009000            988      move.l  #EHBASIC_BASE,a0
00007FB4  4E90                     989      jsr     (a0)                * jump to EhBASIC 
00007FB6                           990  
00007FB6                           991      * I don't think EhBASIC can return back to the monitor but just in case it can
00007FB6                           992      * print out a message and wait for a reset.
00007FB6  41FA 0946                993      lea     strBASICReturn(PC), a0
00007FBA  6100 05C6                994      bsr.w   putString
00007FBE                           995  .forever:
00007FBE  60FE                     996      bra.s   .forever
00007FC0                           997  
00007FC0                           998  *------------------------------------------------------------------------------
00007FC0                           999  * (C) Boot CP/M-68K v1.3
00007FC0                          1000  *------------------------------------------------------------------------------
00007FC0                          1001  cmdBootCPM:
00007FC0                          1002      * perform a simple check to see if CP/M has been programmed into the EEPROM
00007FC0                          1003      * by reading address 0x0400 in the EEPROM. If it contains 0xFFFF then CP/M
00007FC0                          1004      * hasn't been programmed in!
00007FC0  0C78 FFFF 0400          1005      cmpi.w  #$FFFF,CPM_BASE
00007FC6  660C                    1006      bne.s   .chkBIOS
00007FC8  41FA 084F               1007      lea     strCPMErr1(PC), a0
00007FCC  6100 05B4               1008      bsr.w   putString
00007FD0  6000 FF4C               1009      bra.w   monLoop
00007FD4                          1010      
00007FD4                          1011  .chkBIOS:   
00007FD4                          1012      * perform a simple check to see if the BIOS has been programmed into the EEPROM
00007FD4                          1013      * by reading address 0x0400 in the EEPROM. If it contains 0xFFFF then the CP/M
00007FD4                          1014      * BIOS hasn't been programmed in!
00007FD4  0C78 FFFF 6000          1015      cmpi.w  #$FFFF,$6000
00007FDA  660C                    1016      bne.s   .bootCPM
00007FDC  41FA 0873               1017      lea     strCPMErr2(PC), a0
00007FE0  6100 05A0               1018      bsr.w   putString
00007FE4  6000 FF38               1019      bra.w   monLoop
00007FE8                          1020      
00007FE8                          1021  .bootCPM:
00007FE8  207C 00000400           1022      move.l  #CPM_BASE,a0
00007FEE  4E90                    1023      jsr     (a0)            * jump to CP/M-68K 
00007FF0                          1024      
00007FF0                          1025      * I don't think CP/M-68K can return back to the moitor but just in case it can
00007FF0                          1026      * print out a message and wait for a reset.
00007FF0  41FA 089C               1027      lea     strCPMReturn(PC), a0
00007FF4  6100 058C               1028      bsr.w   putString
00007FF8                          1029  .forever:
00007FF8  60FE                    1030      bra.s   .forever
00007FFA                          1031      
00007FFA                          1032  *------------------------------------------------------------------------------
00007FFA                          1033  * (D)ump memory
00007FFA                          1034  * Display 256 bytes of memory as ASCII-HEX characters
00007FFA                          1035  *------------------------------------------------------------------------------
00007FFA                          1036  cmdDispMemory:
00007FFA  6100 03D6               1037      bsr.w   putc                * echo back the command character in D0
00007FFE  103C 0020               1038      move.b  #' ',d0
00008002  6100 03CE               1039      bsr.w   putc
00008006                          1040      
00008006  4282                    1041      clr.l   d2                  * pre-set D2 to 0
00008008  7208                    1042      move.l  #8,d1               * read up to 8 digits
0000800A  6100 02C6               1043      bsr.w   hexToIntEcho        * from the serial port into D0
0000800E  6500 FF0E               1044      bcs.w   monLoop             * back to prompt if there's an error
00008012                          1045      
00008012  2040                    1046      move.l  d0,a0               * A0 holds the start address
00008014  6100 01F8               1047      bsr.w   dumpRAM
00008018                          1048  
00008018  6000 FF04               1049      bra.w   monLoop
0000801C                          1050  
0000801C                          1051  *------------------------------------------------------------------------------
0000801C                          1052  * (G)o - execute code in memory starting at the specified address
0000801C                          1053  *------------------------------------------------------------------------------
0000801C                          1054  cmdRun:
0000801C  6100 03B4               1055      bsr.w   putc                * echo back the command character in D0
00008020  103C 0020               1056      move.b  #' ',d0
00008024  6100 03AC               1057      bsr.w   putc
00008028                          1058  
00008028  4282                    1059      clr.l   d2                  * pre-set D2 to 0
0000802A  7208                    1060      move.l  #8,d1               * read up to 8 digits
0000802C  6100 02A4               1061      bsr.w   hexToIntEcho        * from the serial port
00008030  6500 FEEC               1062      bcs.w   monLoop             * back to prompt if there's an error
00008034                          1063  
00008034  2040                    1064      move.l  d0, a0              * copy start address into A0
00008036  4E90                    1065      jsr     (a0)                * jump to user code
00008038                          1066      
00008038  41FA 078B               1067      lea     strUserReturn(PC),a0
0000803C  6100 0544               1068      bsr.w   putString
00008040                          1069      
00008040  6000 FEDC               1070      bra.w   monLoop
00008044                          1071  
00008044                          1072  *------------------------------------------------------------------------------
00008044                          1073  * (I)nput a byte from I/O space address
00008044                          1074  *------------------------------------------------------------------------------
00008044                          1075  cmdIORead:
00008044  6100 038C               1076      bsr.w   putc                * echo back the command character in D0
00008048  103C 0020               1077      move.b  #' ',d0
0000804C  6100 0384               1078      bsr.w   putc
00008050                          1079  
00008050  4282                    1080      clr.l   d2                  * pre-set D2 to 0
00008052  7202                    1081      move.l  #2,d1               * read up to 2 digit address
00008054  6100 027C               1082      bsr.w   hexToIntEcho        * from the serial port
00008058  6500 FEC4               1083      bcs.w   monLoop             * back to prompt if there's an error
0000805C  1600                    1084      move.b  d0,d3               * save the typed in 8-bit address
0000805E  103C 003D               1085      move.b  #'=',d0
00008062  6100 036E               1086      bsr.w   putc                * send an EQUALS
00008066                          1087  
00008066                          1088      ; D3 = 8-bit address
00008066  207C 00F80000           1089      movea.l #IO_BASE,a0
0000806C  0283 000000FF           1090      andi.l  #$FF,d3             * clear all the unused bits
00008072  E383                    1091      asl.l   #1,d3               * make it a word offset
00008074  5283                    1092      addi.l  #1,d3               * make it an odd address to read from D0..D7
00008076  1030 3000               1093      move.b  (0,a0,d3),d0        * and read the new value in
0000807A  6100 04E0               1094      bsr.w   writeByte           * display the value
0000807E  6100 04FE               1095      bsr.w   putCRLF
00008082  6000 FE9A               1096      bra.w   monLoop
00008086                          1097  
00008086                          1098  *------------------------------------------------------------------------------
00008086                          1099  * (M)odify memory
00008086                          1100  * Change memory contents 1 byte at a time
00008086                          1101  *------------------------------------------------------------------------------
00008086                          1102  cmdModifyMemory:
00008086  6100 034A               1103      bsr.w   putc                * echo back the command character in D0
0000808A  103C 0020               1104      move.b  #' ',d0
0000808E  6100 0342               1105      bsr.w   putc
00008092                          1106  
00008092  4282                    1107      clr.l   d2                  * pre-set D2 to 0
00008094  7208                    1108      move.l  #8,d1               * read up to 8 digits
00008096  6100 023A               1109      bsr.w   hexToIntEcho        * from the serial port
0000809A  6500 FE82               1110      bcs.w   monLoop             * back to prompt if there's an error
0000809E  1200                    1111      move.b  d0,d1               * save the typed in address
000080A0  6100 04DC               1112      bsr.w   putCRLF
000080A4  1001                    1113      move.b  d1,d0               * restore the typed in address
000080A6                          1114      
000080A6  2040                    1115      move.l  d0,a0               * copy address into A0
000080A8                          1116  .cMM_1:
000080A8  6100 0494               1117      bsr.w   writeAddr32         * display the memory location address
000080AC  103C 0020               1118      move.b  #' ',d0
000080B0  6100 0320               1119      bsr.w   putc
000080B4  1010                    1120      move.b  (a0),d0             * get the current memory contents
000080B6  1400                    1121      move.b  d0,d2               * pre-set D2 to the existing memory value
000080B8  6100 04A2               1122      bsr.w   writeByte           * display the byte
000080BC  103C 0020               1123      move.b  #' ',d0
000080C0  6100 0310               1124      bsr.w   putc
000080C4  7202                    1125      move.l  #2,d1               * read up to 2 digits
000080C6  6100 020A               1126      bsr.w   hexToIntEcho        * from the serial port
000080CA  6500 0010               1127      bcs.w   .cMM_2              * back to prompt if there's an error
000080CE                          1128  
000080CE  10C0                    1129      move.b  d0,(a0)+            * write out the new byte and move on
000080D0  2F08                    1130      move.l  a0,-(SP)            * save our address
000080D2  6100 04AA               1131      bsr.w   putCRLF
000080D6  205F                    1132      move.l  (SP)+,a0            * restore our address
000080D8  2008                    1133      move.l  a0,d0               * copy address back into D0 for printing
000080DA  60CC                    1134      bra.s   .cMM_1
000080DC                          1135  
000080DC                          1136  .cMM_2:
000080DC  6100 04A0               1137      bsr.w   putCRLF
000080E0  6000 FE3C               1138      bra.w   monLoop
000080E4                          1139      
000080E4                          1140  *------------------------------------------------------------------------------
000080E4                          1141  * (O)utput a byte to I/O space address
000080E4                          1142  *------------------------------------------------------------------------------
000080E4                          1143  cmdIOWrite:
000080E4  6100 02EC               1144      bsr.w   putc                * echo back the command character in D0
000080E8  103C 0020               1145      move.b  #' ',d0
000080EC  6100 02E4               1146      bsr.w   putc
000080F0                          1147  
000080F0  4282                    1148      clr.l   d2                  * pre-set D2 to 0
000080F2  7202                    1149      move.l  #2,d1               * read up to 2 digit address
000080F4  6100 01DC               1150      bsr.w   hexToIntEcho        * from the serial port
000080F8  6500 FE24               1151      bcs.w   monLoop             * back to prompt if there's an error
000080FC  1600                    1152      move.b  d0,d3               * save the typed in 8-bit address
000080FE  103C 003D               1153      move.b  #'=',d0
00008102  6100 02CE               1154      bsr.w   putc                * send an EQUALS
00008106                          1155  
00008106  4282                    1156      clr.l   d2                  * pre-set D2 to 0
00008108  7202                    1157      move.l  #2,d1               * read up to 2 digit value
0000810A  6100 01C6               1158      bsr.w   hexToIntEcho        * from the serial port
0000810E  6500 FE0E               1159      bcs.w   monLoop             * back to prompt if there's an error
00008112                          1160  
00008112                          1161      ; D0 = value and D3 = 8-bit address
00008112  207C 00F80000           1162      movea.l #IO_BASE,a0
00008118  0283 000000FF           1163      andi.l  #$FF,d3             * clear all the unused bits
0000811E  E383                    1164      asl.l   #1,d3               * make it a word offset
00008120  5283                    1165      addi.l  #1,d3               * make it an odd address to write to D0..D7
00008122  1180 3000               1166      move.b  d0,(0,a0,d3)        * and write the new value out
00008126                          1167  
00008126  6100 0456               1168      bsr.w   putCRLF
0000812A  6000 FDF2               1169      bra.w   monLoop
0000812E                          1170  
0000812E                          1171  *------------------------------------------------------------------------------
0000812E                          1172  * (S) - download a single line of a Motorola S-Record
0000812E                          1173  *------------------------------------------------------------------------------
0000812E                          1174  cmdDownload:
0000812E  6100 02B4               1175      bsr.w   getc                * get the S-Record type
00008132  B03C 0031               1176      cmp.b   #'1', d0
00008136  671A                    1177      beq.s   .cdl_S1             * read in an S1 record
00008138  B03C 0032               1178      cmp.b   #'2', d0
0000813C  6738                    1179      beq.s   .cdl_S2             * read in an S2 record
0000813E  B03C 0038               1180      cmp.b   #'8', d0
00008142  6700 00A8               1181      beq.w   .cdl_EOL89          * handle S8 SRec terminator
00008146  B03C 0039               1182      cmp.b   #'9', d0
0000814A  6700 00A0               1183      beq.w   .cdl_EOL89          * handle S9 SRec terminator
0000814E                          1184  
0000814E  6600 008A               1185      bne     .cdl_EOL            * not S1 or S2 so ignore to end of line
00008152                          1186              
00008152                          1187  .cdl_S1:        
00008152  4282                    1188      clr.l   d2
00008154  123C 0002               1189      move.b  #2, d1              * 2 characters to read
00008158  6100 013E               1190      bsr     hexToInt            * convert to byte count
0000815C  2C00                    1191      move.l  d0, d6              * D6 = byte count
0000815E  2E00                    1192      move.l  d0, d7              * D7 = byte count (running checksum)
00008160                          1193  
00008160  4282                    1194      clr.l   d2
00008162  123C 0004               1195      move.b  #4, d1              * 4 characters to read
00008166  6100 0130               1196      bsr     hexToInt            * convert to address
0000816A  2640                    1197      movea.l d0, a3              * A3 = destination address
0000816C  DE00                    1198      add.b   d0, d7              * update checksum with bits 00..07
0000816E  E088                    1199      lsr.l   #8, d0
00008170  DE00                    1200      add.b   d0, d7              * update checksum with bits 08..15
00008172                          1201  
00008172  5746                    1202      subq.w  #3, D6              * take off the 3 bytes we just read in
00008174                          1203  
00008174  6026                    1204      bra.s   .cdl_1              
00008176                          1205                  
00008176                          1206  .cdl_S2:            
00008176  4282                    1207      clr.l   d2
00008178  123C 0002               1208      move.b  #2, d1              * 2 characters to read
0000817C  6100 011A               1209      bsr     hexToInt            * convert to byte count
00008180  2C00                    1210      move.l  d0, d6              * D6 = byte count
00008182  2E00                    1211      move.l  d0, d7              * D7 = byte count (running checksum)
00008184                          1212  
00008184  4282                    1213      clr.l   d2
00008186  123C 0006               1214      move.b  #6, d1              * 6 characters to read
0000818A  6100 010C               1215      bsr     hexToInt            * convert to address
0000818E  2640                    1216      movea.l d0, a3              * A3 = destination address
00008190  DE00                    1217      add.b   d0, d7              * update checksum with bits 00..07
00008192  E088                    1218      lsr.l   #8, d0
00008194  DE00                    1219      add.b   d0, d7              * update checksum with bits 08..15
00008196  E088                    1220      lsr.l   #8, d0
00008198  DE00                    1221      add.b   d0, d7              * update checksum with bits 16..23
0000819A                          1222  
0000819A  5946                    1223      subq.w  #4, d6              * take off the 4 bytes we just read in
0000819C                          1224  
0000819C                          1225  .cdl_1:
0000819C  4A46                    1226      tst.w   d6                  * read all the bytes yet?
0000819E  6712                    1227      beq.s   .cdl_2
000081A0                          1228  
000081A0  4282                    1229      clr.l   d2
000081A2  323C 0002               1230      move.w  #2, d1              * 2 characters to read
000081A6  6100 00F0               1231      bsr     hexToInt            * convert to data byte
000081AA  16C0                    1232      move.b  d0, (a3)+           * write the byte to memory
000081AC  DE00                    1233      add.b   d0, d7              * update checksum
000081AE  5346                    1234      subq.w  #1, d6              * decrement byte count
000081B0  60EA                    1235      bra.s   .cdl_1
000081B2                          1236  
000081B2                          1237  .cdl_2:
000081B2  4282                    1238      clr.l   d2
000081B4  323C 0002               1239      move.w  #2, d1              * 2 characters to read
000081B8  6100 00DE               1240      bsr     hexToInt            * convert to checksum byte
000081BC  DE00                    1241      add.b   d0, d7              * D7 = calc checksum + srec checksum
000081BE  5207                    1242      addq.b  #1, d7              * checksum + 1 should = 0 if OK
000081C0  670C                    1243      beq.s   .cdl_X
000081C2                          1244  
000081C2  103C 0058               1245      move.b  #'X', d0            * checksum fail - print an X
000081C6  6100 020A               1246      bsr     putc
000081CA  6000 FD5A               1247      bra.w   monLoop_NP          * return to main loop without prompt
000081CE                          1248  
000081CE                          1249  .cdl_X
000081CE  103C 002E               1250      move.b  #'.', d0            * checksum good - print a dot
000081D2  6100 01FE               1251      bsr     putc
000081D6  6000 FD4E               1252      bra.w   monLoop_NP          * return to main loop without prompt
000081DA                          1253  
000081DA                          1254  .cdl_EOL
000081DA  6100 0208               1255      bsr.w   getc                * discard chars until CR or LF
000081DE  0C00 000D               1256      cmpi.b  #CR,d0
000081E2  67EA                    1257      beq.s   .cdl_X
000081E4  0C00 000A               1258      cmpi.b  #LF,d0
000081E8  67E4                    1259      beq.s   .cdl_X
000081EA  60EE                    1260      bra.s   .cdl_EOL
000081EC                          1261  
000081EC                          1262  .cdl_EOL89
000081EC  6100 01F6               1263      bsr.w   getc                * discard chars until CR or LF
000081F0  0C00 000D               1264      cmpi.b  #CR,d0
000081F4  6700 FD9C               1265      beq.w   monLoop_CRLF        * return to main loop with prompt
000081F8  0C00 000A               1266      cmpi.b  #LF,d0
000081FC  6700 FD94               1267      beq.w   monLoop_CRLF        * return to main loop with prompt
00008200  60EA                    1268      bra.s   .cdl_EOL89
00008202                          1269      
