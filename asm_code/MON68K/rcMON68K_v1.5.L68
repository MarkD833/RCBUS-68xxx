00008310                          1448  *******************************************************************************
00008310                          1449  *
00008310                          1450  *   #####  ####### ######  ###    #    #          ######  ####### ######  ####### 
00008310                          1451  *  #     # #       #     #  #    # #   #          #     # #     # #     #    #    
00008310                          1452  *  #       #       #     #  #   #   #  #          #     # #     # #     #    #    
00008310                          1453  *   #####  #####   ######   #  #     # #          ######  #     # ######     #    
00008310                          1454  *        # #       #   #    #  ####### #          #       #     # #   #      #    
00008310                          1455  *  #     # #       #    #   #  #     # #          #       #     # #    #     #    
00008310                          1456  *   #####  ####### #     # ### #     # #######    #       ####### #     #    #    
00008310                          1457  *                                                                                                   
00008310                          1458  *******************************************************************************
00008310                          1459  
00008310                          1460  *------------------------------------------------------------------------------
00008310                          1461  * Initialise the serial port
00008310                          1462  *
00008310                          1463  * Assumes that there is a 68681 DUART at the address defined by DUART1 in
00008310                          1464  * devices.inc and initialises port A and enables the rx interrupt.
00008310                          1465  *------------------------------------------------------------------------------
00008310                          1466  serInit:
00008310  13FC 0030 00D00005      1467      move.b  #$30, CRA           * Reset Transmitter
00008318  13FC 0020 00D00005      1468      move.b  #$20, CRA           * Reset Receiver
00008320  13FC 0010 00D00005      1469      move.b  #$10, CRA           * Reset Mode Register Pointer
00008328                          1470      
00008328  23FC 00000000 001FF800  1471      move.l  #0,ser0RxHead       * Set queue head and tail ptrs to 0
00008332  33FC 0000 001FF804      1472      move.w  #0,ser0RxSize       * No chars in receive queue
0000833A                          1473  
0000833A  13FC 0000 00D00009      1474      move.b  #$00, ACR           * Baud Rate Set #1
00008342  13FC 0013 00D00001      1475      move.b  #$13, MRA           * No Parity & 8-bit
0000834A  13FC 0007 00D00001      1476      move.b  #$07, MRA           * Normal Mode, No CTS/RTS & 1 stop bit
00008352                          1477  
00008352                          1478      * if HI_SPEED = 0 then set 38400 baud
00008352                 TRUE     1479      ifeq HI_SPEED
00008352  13FC 00CC 00D00003      1480      move.b  #BAUD_38400, CSRA   * Set Tx and Rx baud rates to 38400
0000835A                          1481      endc
0000835A                          1482  
0000835A                          1483      * if HI_SPEED > 0 then set 115200 baud
0000835A                 FALSE    1484      ifgt HI_SPEED
0000835A                          1485      endc
0000835A                          1486      
0000835A  13FC 0002 00D0000B      1487      move.b  #$02, IMR           * Rx interrupt enabled
00008362  13FC 0005 00D00005      1488      move.b  #$05, CRA           * Enable Transmit/Recieve
0000836A  13FC 0001 00D0001D      1489      move.b  #$01, SOPR          * set OP0 low - i.e. CTS low
00008372  4E75                    1490      rts
00008374                          1491  
00008374                          1492  *------------------------------------------------------------------------------
00008374                          1493  * Serial port interrupt handler
00008374                          1494  *
00008374                          1495  * Should only be called when a char has been received.
00008374                          1496  *
00008374                          1497  *------------------------------------------------------------------------------
00008374                          1498  serISR:
00008374                          1499      * save registers we are about to trash
00008374  48E7 E080               1500      movem.l d0-d2/a0,-(sp)
00008378                          1501  
00008378  0839 0001 00D0000B      1502      btst.b  #1,ISR              * check the RXRDYA bit
00008380  6700 004A               1503      beq.w   serExit
00008384                          1504  
00008384                          1505      * a char has been received so save it in the rx queue
00008384  1039 00D00007           1506      move.b  RBA,d0              * get the character
0000838A  207C 001FF800           1507      movea.l #ser0RxQueue,a0     * A0 = ptr to rx queue parameters
00008390  2210                    1508      move.l  (a0),d1             * D1.L MSW = head and LSW = tail
00008392  4841                    1509      swap    d1                  * D1.L MSW = tail and LSW = head
00008394  3401                    1510      move.w  d1,d2               * D2.W holds the queue head index
00008396  4841                    1511      swap    d1                  * D1.L MSW = head and LSW = tail
00008398                          1512  
00008398                          1513  
00008398  5242                    1514      addq.w  #1,d2               * advance the head index
0000839A  0242 00FF               1515      andi.w  #SERIAL_BUFFER_MASK,d2
0000839E  B441                    1516      cmp.w   d1,d2               * if head = tail then buffer full
000083A0  6604                    1517      bne.s   serSave             * if head <> tail then add char to buffer
000083A2                          1518  
000083A2                          1519      * the serial buffer is full - what now?
000083A2  6000 0028               1520      bra.w   serExit
000083A6                          1521  
000083A6                          1522  serSave:
000083A6  4841                    1523      swap    d1                  * D1.L MSW = tail and LSW = head
000083A8  0281 0000FFFF           1524      andi.l  #$0000FFFF,d1       * D1 holds just the old head index
000083AE  1180 1006               1525      move.b  d0,6(a0,d1)         * save the char to the rx queue
000083B2  3082                    1526      move.w  d2,(a0)             * save the updated head index
000083B4  5279 001FF804           1527      addq.w  #1,ser0RxSize       * increment number of chars in rx queue
000083BA                          1528  
000083BA                          1529      * check if rx queue is nearly full
000083BA  0C79 00C8 001FF804      1530      cmpi.w  #SERIAL_BUFFER_UPPER,ser0RxSize
000083C2  6F08                    1531      ble.s   serExit
000083C4                          1532  
000083C4                          1533      * no of chars in queue has reached the upper threshold
000083C4                          1534      * set CTS HIGH to hopefully tell the host to stop sending.
000083C4  13FC 0001 00D0001F      1535      move.b  #$01, ROPR          * set OP0 high
000083CC                          1536  
000083CC                          1537  serExit:
000083CC                          1538      * restore registers
000083CC  4CDF 0107               1539      movem.l (sp)+,d0-d2/a0
000083D0  4E73                    1540      rte
000083D2                          1541  
000083D2                          1542  *------------------------------------------------------------------------------
000083D2                          1543  * Write a character directly to UART Port A, blocking if UART is not ready
000083D2                          1544  *
000083D2                          1545  * D0 = char to send
000083D2                          1546  *------------------------------------------------------------------------------
000083D2                          1547  putc:
000083D2  0839 0002 00D00003      1548      btst.b  #2, SRA             * Check if transmitter ready bit is set
000083DA  67F6                    1549      beq     putc     
000083DC  13C0 00D00007           1550      move.b  d0, TBA             * Transmit Character
000083E2  4E75                    1551      rts
000083E4                          1552  
000083E4                          1553  *------------------------------------------------------------------------------
000083E4                          1554  * Read a character from the rx queue - blocking call so will wait for character
000083E4                          1555  *
000083E4                          1556  * D0 = recevied char
000083E4                          1557  *------------------------------------------------------------------------------
000083E4                          1558  getc:
000083E4  0C79 0000 001FF804      1559      cmpi.w  #0,ser0RxSize       * check number of chars in rx queue
000083EC  67F6                    1560      beq.s   getc                * keep checking till there is a char available
000083EE                          1561  
000083EE                          1562      * save registers we are about to trash
000083EE  48E7 4080               1563      movem.l d1/a0,-(sp)
000083F2                          1564      
000083F2                          1565      * get the character from the tail of the queue
000083F2  207C 001FF800           1566      movea.l #ser0RxQueue,a0     * A0 = ptr to rx queue parameters
000083F8  2210                    1567      move.l  (a0),d1             * D1.L MSW = head and LSW = tail
000083FA  1030 1006               1568      move.b  6(a0,d1.w),d0       * read the char from the queue tail
000083FE  5241                    1569      addq.w  #1,d1               * advance the tail index
00008400  0241 00FF               1570      andi.w  #SERIAL_BUFFER_MASK,d1
00008404  3141 0002               1571      move.w  d1,2(a0)            * save the updated tail index
00008408  5379 001FF804           1572      subq.w  #1,ser0RxSize       * decrement number of chars in rx queue
0000840E                          1573  
0000840E                          1574      * check if rx queue is nearly empty
0000840E  0C79 0019 001FF804      1575      cmpi.w  #SERIAL_BUFFER_LOWER,ser0RxSize
00008416  6C08                    1576      bge.s   getExit
00008418                          1577  
00008418                          1578      * no of chars in queue has reached the lower threshold
00008418                          1579      * set CTS LOW to hopefully tell the host to start sending.
00008418  13FC 0001 00D0001D      1580      move.b  #$01, SOPR          * set OP0 low
00008420                          1581  
00008420                          1582  getExit:
00008420                          1583      * restore registers
00008420  4CDF 0102               1584      movem.l (sp)+,d1/a0
00008424  4E75                    1585      rts
00008426                          1586  
00008426                          1587  *******************************************************************************
00008426                          1588  *
00008426                          1589  *  #######    #     #####  #     #  #####   #####  #    #    ####### ######     #    ######   #####  
00008426                          1590  *  #         # #   #     #  #   #  #     # #     # #   #        #    #     #   # #   #     # #     # 
00008426                          1591  *  #        #   #  #         # #   #       #     # #  #         #    #     #  #   #  #     # #       
00008426                          1592  *  #####   #     #  #####     #    ######   #####  ###          #    ######  #     # ######   #####  
00008426                          1593  *  #       #######       #    #    #     # #     # #  #         #    #   #   ####### #             # 
00008426                          1594  *  #       #     # #     #    #    #     # #     # #   #        #    #    #  #     # #       #     # 
00008426                          1595  *  ####### #     #  #####     #     #####   #####  #    #       #    #     # #     # #        #####  
00008426                          1596  *                                                                                                   
00008426                          1597  *******************************************************************************
00008426                          1598  
00008426                          1599  *------------------------------------------------------------------------------
