00008274                          1319  *------------------------------------------------------------------------------
00008274                          1320  * Convert character in D0 to upper case
00008274                          1321  * Only changes D0 if char is between 'a'..'z'
00008274                          1322  *------------------------------------------------------------------------------
00008274                          1323  chToUpper:
00008274  B03C 0061               1324      cmp.b   #'a', d0         
00008278  6D0A                    1325      blt.s   .done               * less than lower-case 'a' so leave alone
0000827A  B03C 007A               1326      cmp.b   #'z', d0
0000827E  6E04                    1327      bgt.s   .done               * greater than lower-case 'z' so leave alone
00008280  0400 0020               1328      sub.b   #$20, d0            * convert to upper case
00008284                          1329  .done:
00008284  4E75                    1330      rts
00008286                          1331      
00008286                          1332  *------------------------------------------------------------------------------
00008286                          1333  * Convert a byte into a print safe character
00008286                          1334  * Substitute a '.' for any byte <32 or >126
00008286                          1335  * D0 holds the byte
00008286                          1336  *------------------------------------------------------------------------------
00008286                          1337  makePrintable:
00008286  B03C 0020               1338      cmp.b   #' ', d0         
0000828A  6D06                    1339      blt.s   .mp_1               * less than a SPACE (char 32)
0000828C                          1340  
0000828C  B03C 007E               1341      cmp.b   #'~', d0         
00008290  6F04                    1342      ble.s   .mp_x               * less than a DEL (char 127)
00008292                          1343  
00008292                          1344  .mp_1:
00008292  103C 002E               1345      move.b  #'.',d0             * substitute a DOT (char 46)
00008296                          1346  .mp_x:
00008296  4E75                    1347      rts
00008298                          1348      
00008298                          1349  *--------------------------------------------------------------------------
00008298                          1350  * Read in an ASCII-HEX number - no echo back
00008298                          1351  *
00008298                          1352  * D2 = Value to return if no digits read in
00008298                          1353  * D1 = Max no of ASCII digits to read in
00008298                          1354  * D0 = Result
00008298                          1355  * Carry flag set if an error occurs / not ASCII-HEX digit
00008298                          1356  *--------------------------------------------------------------------------
00008298                          1357  hexToInt:
00008298                          1358  *   move.l  d2,-(SP)            * save D2
00008298                          1359  *   clr.l   d2                  * D2 used to accumulate the final value
00008298                          1360  .h2i_1:
00008298  6100 014A               1361      bsr.w   getc                * get a character
0000829C  61D6                    1362      bsr.s   chToUpper           * convert to upper case if needed
0000829E                          1363  
0000829E  0C00 000A               1364      cmpi.b  #10,d0              * finish if it's CR or LF
000082A2  6724                    1365      beq.s   .h2i_x
000082A4  0C00 000D               1366      cmpi.b  #13,d0
000082A8  671E                    1367      beq.s   .h2i_x
000082AA                          1368      
000082AA  0400 0030               1369      subi.b  #'0',d0
000082AE  6B1C                    1370      bmi.s   .h2i_err            * quit if char is less than '0'
000082B0                          1371  
000082B0  0C00 0009               1372      cmpi.b  #9,d0
000082B4  6F0A                    1373      ble.s   .h2i_2              * is it <= 9
000082B6                          1374      
000082B6  5F00                    1375      subi.b  #7,d0
000082B8  6B12                    1376      bmi.s   .h2i_err            * quit if char is >'9' and <'A'
000082BA                          1377  
000082BA  0C00 000F               1378      cmpi.b  #15,d0
000082BE  6E0C                    1379      bgt.s   .h2i_err            * quit if char is >'F'
000082C0                          1380  
000082C0                          1381  .h2i_2:
000082C0  E98A                    1382      lsl.l   #4, d2
000082C2  8400                    1383      or.b    d0, d2              * insert the new digit
000082C4                          1384  
000082C4  5301                    1385      subq.b  #1, d1              * decrement the digit count
000082C6  66D0                    1386      bne.s   .h2i_1              * go back for another digit?
000082C8                          1387  
000082C8                          1388  .h2i_x:
000082C8  2002                    1389      move.l  d2,d0               * put the answer back into D0
000082CA                          1390  *   move.l  (SP)+,d2            * restore D2
000082CA  4E75                    1391      rts
000082CC                          1392  
000082CC                          1393  .h2i_err:
000082CC                          1394  *   move.l  (SP)+,d2            * restore D2
000082CC  003C 0001               1395      ori.b   #1,CCR              * set the CARRY flag to signal an error
000082D0  4E75                    1396      rts
000082D2                          1397  
000082D2                          1398  *--------------------------------------------------------------------------
000082D2                          1399  * Read in an ASCII-HEX number with echo back
000082D2                          1400  *
000082D2                          1401  * D2 = Value to return if no digits read in
000082D2                          1402  * D1 = Max no of ASCII digits to read in
000082D2                          1403  * D0 = Result
000082D2                          1404  * Carry flag set if an error occurs / not ASCII-HEX digit
000082D2                          1405  *--------------------------------------------------------------------------
000082D2                          1406  hexToIntEcho:
000082D2                          1407  *   move.l  d2,-(SP)            * save D2
000082D2                          1408  *   clr.l   d2                  * D2 used to accumulate the final value
000082D2                          1409  .h2i_1:
000082D2  6100 0110               1410      bsr.w   getc                * get a character
000082D6  6100 00FA               1411      bsr.w   putc                * echo it back
000082DA  6198                    1412      bsr.s   chToUpper           * convert to upper case if needed
000082DC                          1413  
000082DC  0C00 000A               1414      cmpi.b  #10,d0              * finish if it's CR or LF
000082E0  6724                    1415      beq.s   .h2i_x
000082E2  0C00 000D               1416      cmpi.b  #13,d0
000082E6  671E                    1417      beq.s   .h2i_x
000082E8                          1418      
000082E8  0400 0030               1419      subi.b  #'0',d0
000082EC  6B1C                    1420      bmi.s   .h2i_err            * quit if char is less than '0'
000082EE                          1421  
000082EE  0C00 0009               1422      cmpi.b  #9,d0
000082F2  6F0A                    1423      ble.s   .h2i_2              * is it <= 9
000082F4                          1424      
000082F4  5F00                    1425      subi.b  #7,d0
000082F6  6B12                    1426      bmi.s   .h2i_err            * quit if char is >'9' and <'A'
000082F8                          1427  
000082F8  0C00 000F               1428      cmpi.b  #15,d0
000082FC  6E0C                    1429      bgt.s   .h2i_err            * quit if char is >'F'
000082FE                          1430  
000082FE                          1431  .h2i_2:
000082FE  E98A                    1432      lsl.l   #4, d2
00008300  8400                    1433      or.b    d0, d2              * insert the new digit
00008302                          1434  
00008302  5301                    1435      subq.b  #1, d1              * decrement the digit count
00008304  66CC                    1436      bne.s   .h2i_1              * go back for another digit?
00008306                          1437  
00008306                          1438  .h2i_x:
00008306  2002                    1439      move.l  d2,d0               * put the answer back into D0
00008308                          1440  *   move.l  (SP)+,d2            * restore D2
00008308  4E75                    1441      rts
0000830A                          1442  
0000830A                          1443  .h2i_err:
0000830A                          1444  *   move.l  (SP)+,d2            * restore D2
0000830A  003C 0001               1445      ori.b   #1,CCR              * set the CARRY flag to signal an error
0000830E  4E75                    1446      rts
