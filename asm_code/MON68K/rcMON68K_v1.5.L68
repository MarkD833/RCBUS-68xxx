0000848E                          1631  *------------------------------------------------------------------------------
0000848E                          1632  * These are the EASy68K tasks that are not yet implemented
0000848E                          1633  * Simply print out a message showing the task number and stop in an endless loop.
0000848E                          1634  *------------------------------------------------------------------------------
0000848E                          1635  
0000848E                          1636  easyTask2: 
0000848E                          1637  easyTask3:
0000848E                          1638  easyTask4:
0000848E                          1639  easyTask8: 
0000848E                          1640  easyTask9: 
0000848E                          1641  easyTask10:
0000848E                          1642  easyTask11:
0000848E                          1643  easyTask12:
0000848E                          1644  easyTask15:
0000848E                          1645  easyTask16:
0000848E                          1646  easyTask17:
0000848E                          1647  easyTask18:
0000848E                          1648  easyTask19:
0000848E                          1649  easyTask20:
0000848E                          1650  easyTask21:
0000848E                          1651  easyTask22:
0000848E                          1652  easyTask23:
0000848E                          1653  easyTask24:
0000848E                          1654  easyTask25:
0000848E                          1655  easyTaskUnsupported:
0000848E  C141                    1656      exg     d0,d1               * put the task number into D1
00008490  41FA 034F               1657      lea     strEasyTask1(PC), a0
00008494  6100 00EC               1658      bsr.w   putString
00008498  C141                    1659      exg     d0,d1               * put the task number back into D0
0000849A  80FC 000A               1660      divu    #10,d0              * divide task number by 10
0000849E  6100 00C4               1661      bsr.w   writeNibble         * output the 10's digit
000084A2  4840                    1662      swap    d0
000084A4  6100 00BE               1663      bsr.w   writeNibble         * output the 1's digit
000084A8  41FA 0358               1664      lea     strEasyTask2(PC), a0
000084AC  6100 00D4               1665      bsr.w   putString
000084B0                          1666  .infloop:
000084B0  60FE                    1667      bra.s   .infloop
000084B2                          1668  
000084B2                          1669  *------------------------------------------------------------------------------
000084B2                          1670  * EASy68K TRAP #15 - Task 0
000084B2                          1671  * Display n characters of string at (A1), n is D1.W (stops on NULL or max 255) with CR, LF.
000084B2                          1672  *------------------------------------------------------------------------------
000084B2                          1673  easyTask0:
000084B2  0241 00FF               1674      andi.w  #$00FF,d1           * DBRA works on a WORD so make sure upper byte is zero
000084B6  5301                    1675      sub.b   #1,d1               * DBRA requires 1 less than actual number
000084B8                          1676  .loop:
000084B8  1019                    1677      move.b  (a1)+, d0           * Read in character
000084BA  6708                    1678      beq.s   .end                * Check for the null
000084BC                          1679      
000084BC  6100 FF14               1680      bsr.w   putc                * Otherwise write the character
000084C0  51C9 FFF6               1681      dbra    d1,.loop            * And continue
000084C4                          1682  .end:
000084C4  6100 00B8               1683      bsr.w   putCRLF             * append CR & LF
000084C8  4E75                    1684      rts
000084CA                          1685  
000084CA                          1686  *------------------------------------------------------------------------------
000084CA                          1687  * EASy68K TRAP #15 - Task 1
000084CA                          1688  * Display n characters of string at (A1), n is D1.W (stops on NULL or max 255) without CR, LF.
000084CA                          1689  *------------------------------------------------------------------------------
000084CA                          1690  easyTask1:
000084CA  0241 00FF               1691      andi.w  #$00FF,d1           * DBRA works on a WORD so make sure upper byte is zero
000084CE  5301                    1692      sub.b   #1,d1               * DBRA requires 1 less than actual number
000084D0                          1693  .loop:
000084D0  1019                    1694      move.b  (a1)+, d0           * Read in character
000084D2  6708                    1695      beq.s   .end                * Check for the null
000084D4                          1696      
000084D4  6100 FEFC               1697      bsr.w   putc                * Otherwise write the character
000084D8  51C9 FFF6               1698      dbra    d1,.loop            * And continue
000084DC                          1699  .end:
000084DC  4E75                    1700      rts
000084DE                          1701  
000084DE                          1702  *------------------------------------------------------------------------------
000084DE                          1703  * EASy68K TRAP #15 - Task 5
000084DE                          1704  * Read single ASCII character from the keyboard into D1.B. 
000084DE                          1705  *------------------------------------------------------------------------------
000084DE                          1706  easyTask5:
000084DE  6100 FF04               1707      bsr.w   getc                * wait for char - returned in D0
000084E2  1200                    1708      move.b  d0,d1               * move the char into D1
000084E4  4E75                    1709      rts
000084E6                          1710      
000084E6                          1711  *------------------------------------------------------------------------------
000084E6                          1712  * EASy68K TRAP #15 - Task 6
000084E6                          1713  * Display single ASCII character in D1.B.   
000084E6                          1714  *------------------------------------------------------------------------------
000084E6                          1715  easyTask6:
000084E6  1001                    1716      move.b  d1,d0               * move the char into D0
000084E8  6100 FEE8               1717      bsr.w   putc                * output the char
000084EC  4E75                    1718      rts
000084EE                          1719  
000084EE                          1720  *------------------------------------------------------------------------------
000084EE                          1721  * EASy68K TRAP #15 - Task 7
000084EE                          1722  * Check for keyboard input. Set D1.B to 1 if keyboard input is pending,
000084EE                          1723  * otherwise set to 0.
000084EE                          1724  *------------------------------------------------------------------------------
000084EE                          1725  easyTask7:
000084EE  123C 0000               1726      move.b  #0,d1               * assume no char available
000084F2  0C79 0000 001FF804      1727      cmpi.w  #0,ser0RxSize       * check number of chars in rx queue
000084FA  6704                    1728      beq.s   .end
000084FC  123C 0001               1729      move.b  #1,d1               * there is at least 1 char available
00008500                          1730  .end
00008500  4E75                    1731      rts
00008502                          1732  
00008502                          1733  *------------------------------------------------------------------------------
00008502                          1734  * EASy68K TRAP #15 - Task 13
00008502                          1735  * Display the NULL terminated string at (A1) with CR, LF.
00008502                          1736  *------------------------------------------------------------------------------
00008502                          1737  easyTask13:
00008502                          1738  .loop:
00008502  1019                    1739      move.b  (a1)+, d0           * Read in character
00008504  6706                    1740      beq.s   .end                * Check for the null
00008506                          1741      
00008506  6100 FECA               1742      bsr.w   putc                * Otherwise write the character
0000850A  60F6                    1743      bra.s   .loop               * And continue
0000850C                          1744  .end:
0000850C  6100 0070               1745      bsr.w   putCRLF             * append CR & LF
00008510  4E75                    1746      rts
00008512                          1747  
00008512                          1748  *------------------------------------------------------------------------------
00008512                          1749  * EASy68K TRAP #15 - Task 14
00008512                          1750  * Display the NULL terminated string pointed to by (A1).
00008512                          1751  *------------------------------------------------------------------------------
00008512                          1752  easyTask14:
00008512                          1753  .loop:
00008512  1019                    1754      move.b  (a1)+, d0           * Read in character
00008514  6706                    1755      beq.s   .end                * Check for the null
00008516                          1756      
00008516  6100 FEBA               1757      bsr.w   putc                * Otherwise write the character
0000851A  60F6                    1758      bra.s   .loop               * And continue
0000851C                          1759  .end:
0000851C  4E75                    1760      rts
0000851E                          1761  
0000851E                          1762  *------------------------------------------------------------------------------
0000851E                          1763  * This is the entry point for the TRAP #15 handler that gets called when any
0000851E                          1764  * TRAP #15 services are required. Only a few tasks are implemented.
0000851E                          1765  * Unimplemented tasks will produce an error message.
0000851E                          1766  *------------------------------------------------------------------------------
0000851E                          1767  easy68kTrap15:
0000851E  48E7 10A0               1768      movem.l d3/a0/a2,-(sp)
00008522  45FA FF02               1769      lea     easy68kTaskTable(PC),a2
00008526  B03C 0019               1770      cmp.b   #25,d0              * is task number greater than 25?
0000852A  6E00 FF62               1771      bgt     easyTaskUnsupported
0000852E                          1772      
0000852E  4283                    1773      clr.l   d3
00008530  1600                    1774      move.b  d0,d3               * task number into D3
00008532  E58B                    1775      lsl.l   #2,d3               * convert task number into longword offset
00008534  4EB2 3000               1776      jsr     (a2,d3)             * jump to the specific task handler
00008538                          1777      
00008538  4CDF 0508               1778      movem.l (sp)+,d3/a0/a2
0000853C  4E73                    1779      rte
0000853E                          1780  
0000853E                          1781  *******************************************************************************
0000853E                          1782  *
0000853E                          1783  *  ######  ######  ### #     # #######    ######  ####### #     # ####### ### #     # #######  #####  
0000853E                          1784  *  #     # #     #  #  ##    #    #       #     # #     # #     #    #     #  ##    # #       #     # 
0000853E                          1785  *  #     # #     #  #  # #   #    #       #     # #     # #     #    #     #  # #   # #       #       
0000853E                          1786  *  ######  ######   #  #  #  #    #       ######  #     # #     #    #     #  #  #  # #####    #####  
0000853E                          1787  *  #       #   #    #  #   # #    #       #   #   #     # #     #    #     #  #   # # #             # 
0000853E                          1788  *  #       #    #   #  #    ##    #       #    #  #     # #     #    #     #  #    ## #       #     # 
0000853E                          1789  *  #       #     # ### #     #    #       #     # #######  #####     #    ### #     # #######  #####    
0000853E                          1790  *
0000853E                          1791  *******************************************************************************
0000853E                          1792  * These are the various printing routines that handle displaying of bytes,
0000853E                          1793  * words, long words and 24-bit values as ASCII hexadecimal text. The routines
0000853E                          1794  * must be kept in this order as program flow is meant to fall out of one
0000853E                          1795  * routine and into the next, often without a return statement.
0000853E                          1796  *******************************************************************************
0000853E                          1797  
0000853E                          1798  *------------------------------------------------------------------------------
0000853E                          1799  * Output a 32-bit address as 8 ASCII hexadecimal digits
0000853E                          1800  * D0 holds the 32-bit address
0000853E                          1801  *------------------------------------------------------------------------------
0000853E                          1802  writeAddr32:
0000853E  2F00                    1803      move.l  d0,-(sp)            * save D0 first
00008540  E098                    1804      ror.l   #8,d0
00008542  E098                    1805      ror.l   #8,d0
00008544  610E                    1806      bsr.s   writeWord           * write bits 16..31
00008546  201F                    1807      move.l  (sp)+,d0            * restore D0
00008548  600A                    1808      bra.s   writeWord
0000854A                          1809      
0000854A                          1810  *------------------------------------------------------------------------------
0000854A                          1811  * Output a 24-bit address as 6 ASCII hexadecimal digits
0000854A                          1812  * D0 holds the address in bits 0..23
0000854A                          1813  * NOTE: the writeWord function must be directly after this function
0000854A                          1814  *------------------------------------------------------------------------------
0000854A                          1815  writeAddr24:
0000854A  2F00                    1816      move.l  d0,-(sp)            * save D0 first
0000854C  E098                    1817      ror.l   #8,d0
0000854E  E098                    1818      ror.l   #8,d0
00008550  610A                    1819      bsr.s   writeByte           * write bits 16..23
00008552  201F                    1820      move.l  (sp)+,d0            * restore D0
00008554                          1821      
00008554                          1822  *------------------------------------------------------------------------------
00008554                          1823  * Output a word as 4 ASCII hexadecimal digits
00008554                          1824  * D0 holds the word in bits 0..15
00008554                          1825  * NOTE: the writeByte function must be directly after this function
00008554                          1826  *------------------------------------------------------------------------------
00008554                          1827  writeWord:
00008554  3F00                    1828      move.w  d0,-(sp)            * save D0 first
00008556  E058                    1829      ror.w   #8,d0               * get upper byte (0 => shift 8 times)
00008558  6102                    1830      bsr.s   writeByte
0000855A  301F                    1831      move.w  (sp)+,d0            * restore D0
0000855C                          1832  
0000855C                          1833  *------------------------------------------------------------------------------
0000855C                          1834  * Output a byte as 2 ASCII hexadecimal digits
0000855C                          1835  * D0 holds the byte in bits 0..7
0000855C                          1836  * NOTE: the writeNibble function must be directly after this function
0000855C                          1837  *------------------------------------------------------------------------------
0000855C                          1838  writeByte:
0000855C  3F00                    1839      move.w  d0,-(sp)            * save D0 first
0000855E  E818                    1840      ror.b   #4,d0               * get upper nibble
00008560  6102                    1841      bsr.s   writeNibble
00008562  301F                    1842      move.w  (sp)+,d0            * restore D0
00008564                          1843      
00008564                          1844  *------------------------------------------------------------------------------
00008564                          1845  * Output 4 bits as an ASCII hexadecimal digit
00008564                          1846  * D0 holds the nibble in bits 0..3
00008564                          1847  *------------------------------------------------------------------------------
00008564                          1848  writeNibble:
00008564  3F00                    1849      move.w  d0,-(sp)            * save D0 first
00008566  0200 000F               1850      andi.b  #$0F,d0             * make sure we only have the lower 4 bits
0000856A  0C00 000A               1851      cmpi.b  #10,d0              * compare D0 to 10
0000856E  6502                    1852      bcs.b   .wn1                * less than 10 so don't add 7
00008570  5E00                    1853      addi.b  #07,d0              * add 7
00008572                          1854  .wn1:
00008572  0600 0030               1855      addi.b  #'0',d0             * add ASCII code for char zero
00008576  6100 FE5A               1856      bsr.w   putc                * write the ASCII digit out
0000857A  301F                    1857      move.w  (sp)+,d0            * restore D0
0000857C  4E75                    1858      rts
0000857E                          1859  
0000857E                          1860  *------------------------------------------------------------------------------
0000857E                          1861  * Prints a newline (CR, LF)
0000857E                          1862  * NOTE: the putString function must follow this function
0000857E                          1863  *------------------------------------------------------------------------------
0000857E                          1864  putCRLF:
0000857E  41FA 0228               1865      lea     strNewline(PC), a0
00008582                          1866  
00008582                          1867  *------------------------------------------------------------------------------
00008582                          1868  * Print a null terminated string
00008582                          1869  * A0 holds the address of the first character of the null terminated string
00008582                          1870  *------------------------------------------------------------------------------
00008582                          1871  putString:
00008582                          1872  .loop:
00008582  1018                    1873      move.b  (a0)+, d0           * Read in character
00008584  6706                    1874      beq.s   .end                * Check for the null
00008586                          1875      
00008586  6100 FE4A               1876      bsr.w   putc                * Otherwise write the character
0000858A  60F6                    1877      bra.s   .loop               * And continue
0000858C                          1878  .end:
0000858C  4E75                    1879      rts
