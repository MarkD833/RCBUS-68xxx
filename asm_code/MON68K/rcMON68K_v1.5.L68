0000820E                          1278  *------------------------------------------------------------------------------
0000820E                          1279  * Dumps a 256 section of RAM to the screen
0000820E                          1280  * Displays both hex values and ASCII characters
0000820E                          1281  * a0 - Start Address
0000820E                          1282  *------------------------------------------------------------------------------
0000820E                          1283  dumpRAM:
0000820E  48E7 E040               1284      movem.l d0-d2/a1, -(SP)     * Save registers
00008212  2248                    1285      move.l  a0,a1               * move the start address to A1
00008214                          1286  
00008214  6100 0368               1287      bsr.w   putCRLF             * new line - trashes D0 & A0
00008218                          1288      
00008218  323C 000F               1289      move.w  #15,d1              * 16 rows of data (DBRA needs 1 less!)
0000821C                          1290  .dr_1:
0000821C  343C 000F               1291      move.w  #15,d2              * 16 bytes of data per row (DBRA needs 1 less!)
00008220  2009                    1292      move.l  a1, d0              * copy the start address of the line into D0          
00008222  6100 031A               1293      bsr.w   writeAddr32         * Display as a 32-bit hex value
00008226  41FA 0583               1294      lea     strColonSpace(PC), a0
0000822A  6100 0356               1295      bsr.w   putString
0000822E  41F9 001FF906           1296      lea     msgASCIIDump, a0
00008234                          1297  .dr_2:
00008234  1019                    1298      move.b  (a1)+, d0           * Read a byte from RAM
00008236  6100 0324               1299      bsr.w   writeByte           * display byte as 2 hex digits  
0000823A  6100 004A               1300      bsr.w   makePrintable       * convert to printable character
0000823E  10C0                    1301      move.b  d0,(a0)+            * save the printable char in output string
00008240  103C 0020               1302      move.b  #' ', d0
00008244  6100 018C               1303      bsr.w   putc                * insert a space
00008248  51CA FFEA               1304      dbra    d2,.dr_2
0000824C                          1305  
0000824C  103C 0020               1306      move.b  #' ', d0
00008250  6100 0180               1307      bsr.w   putc                * insert a space
00008254                          1308  
00008254  10FC 000D               1309      move.b  #CR,(a0)+
00008258  10FC 000A               1310      move.b  #LF,(a0)+
0000825C  10FC 0000               1311      move.b  #0,(a0)+
00008260  41F9 001FF906           1312      lea     msgASCIIDump, a0
00008266  6100 031A               1313      bsr.w   putString           * print out the printable bytes
0000826A  51C9 FFB0               1314      dbra    d1,.dr_1
0000826E                          1315  
0000826E  4CDF 0207               1316      movem.l (SP)+, d0-d2/a1     * Restore registers
00008272  4E75                    1317      rts
